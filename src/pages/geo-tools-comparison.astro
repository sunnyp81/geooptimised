  <script>
    // FAQ accordion
    document.querySelectorAll('.faq-item button').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        const answer = item.querySelector('.faq-answer');
        const icon = item.querySelector('.faq-icon');
        const isOpen = btn.getAttribute('aria-expanded') === 'true';
        document.querySelectorAll('.faq-item button[aria-expanded="true"]').forEach(other => {
          if (other !== btn) {
            other.setAttribute('aria-expanded', 'false');
            other.closest('.faq-item').querySelector('.faq-answer').style.maxHeight = '0';
            other.closest('.faq-item').querySelector('.faq-icon').style.transform = '';
          }
        });
        btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
        answer.style.maxHeight = isOpen ? '0' : answer.scrollHeight + 'px';
        icon.style.transform = isOpen ? '' : 'rotate(45deg)';
      });
    });

    // Sticky TOC — IntersectionObserver highlights active section
    const headings = document.querySelectorAll('section[id]');
    const tocLinks = document.querySelectorAll('.toc-link');

    if (headings.length && tocLinks.length) {
      const observer = new IntersectionObserver(
        entries => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              tocLinks.forEach(link => {
                link.classList.remove('text-[var(--accent)]', 'border-[var(--accent)]');
                link.classList.add('text-ink-400', 'border-transparent');
              });
              const active = document.querySelector(`.toc-link[href="#${entry.target.id}"]`);
              if (active) {
                active.classList.remove('text-ink-400', 'border-transparent');
                active.classList.add('text-[var(--accent)]', 'border-[var(--accent)]');
              }
            }
          });
        },
        { rootMargin: '-10% 0px -80% 0px', threshold: 0 }
      );
      headings.forEach(h => observer.observe(h));
    }
  </script>

