---
import Base from '../layouts/Base.astro';
import ClaimCard from '../components/ClaimCard.astro';
import GradeBadge from '../components/GradeBadge.astro';
import claimsData from '../data/claims.json';
import toolsData from '../data/tools.json';
import correctionsData from '../data/corrections.json';

const claims = claimsData.claims;
const order = ['VERIFIED', 'REFUTED', 'MISLEADING', 'DIRECTIONAL', 'UNREPRODUCED', 'UNTRACEABLE'];
const tally = order.map(g => ({ grade: g, count: claims.filter(c => c.grade === g).length }));

const untraceable = claims.filter(c => c.grade === 'UNTRACEABLE').length;
// Numerals mid-sentence read badly in prose. Headline keeps the digit; body copy spells it out.
const words = ['Nothing', 'One', 'Two', 'Three', 'Four', 'Five', 'Six', 'Seven', 'Eight', 'Nine', 'Ten'];
const untraceableWord = words[untraceable] ?? String(untraceable);
const survives = claims.filter(c => c.grade === 'VERIFIED' || c.grade === 'DIRECTIONAL').length;
const survivesPct = Math.round((survives / claims.length) * 100);
const featured = claims.find(c => c.id === 'forty-percent');
const ourError = correctionsData.corrections[0];

const payers = toolsData.tools.filter(t => t.affiliate.hasProgram);
const nonPayers = toolsData.tools.filter(t => !t.affiliate.hasProgram);
const enrolled = toolsData.tools.filter(t => t.ourEnrolment === 'enrolled').length;

const title = 'GEOoptimised: the evidence ledger for AI search';
const description = `Three of the most-quoted statistics in AI search have no traceable source. We graded ${claims.length} claims against their primary sources, and we publish exactly what every tool we review pays us.`;

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': 'https://geooptimised.com/#organization',
    name: 'GEOoptimised',
    url: 'https://geooptimised.com',
    description: 'An independent evidence base for AI search visibility. Every published claim is graded by whether it traces to a primary source and reproduces.',
    disambiguatingDescription: 'GEOoptimised covers generative engine optimisation, meaning how brands come to be cited by AI assistants such as ChatGPT, Perplexity, Claude and Google AI Overviews. It is unrelated to geographic, location-based or geo-targeted marketing.',
    knowsAbout: [
      'Generative engine optimisation',
      'Answer engine optimisation',
      'AI search citation behaviour',
      'Evidence grading of marketing claims',
      'AI visibility measurement and its limits',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': 'https://geooptimised.com/#website',
    url: 'https://geooptimised.com',
    name: 'GEOoptimised',
    publisher: { '@id': 'https://geooptimised.com/#organization' },
    inLanguage: 'en-GB',
  },
];
---
<Base title={title} description={description} schema={schema}>
  <!-- Hero. The proof leads: no promise, no dashboard mock. -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-grid" aria-hidden="true"></div>
    <div class="absolute inset-0 hero-fade" aria-hidden="true"></div>

    <div class="wrap relative pt-16 pb-14 md:pt-24 md:pb-20">
      <p class="eyebrow mb-6">
        AI search &middot; Evidence ledger &middot; Checked {claimsData.gradedOn}
      </p>

      <h1 class="font-display font-bold text-[2.35rem] leading-[1.06] sm:text-[3.1rem] md:text-[3.75rem] max-w-[19ch] grad-text">
        {untraceable} of the most-repeated claims in AI search have no source we could find.
      </h1>

      <p class="mt-7 max-w-[62ch] text-[1.12rem]" style="color: var(--text-soft);">
        We went looking for the primary source behind every number this industry repeats. Some reproduced
        exactly. One drifted by a factor of ten in the retelling. {untraceableWord} lead nowhere at all. Below
        is the ledger, and beneath it, the list of every tool we review and precisely what each one pays us.
      </p>

      <div class="mt-9 flex flex-wrap items-center gap-4">
        <a href="/evidence/" class="btn btn-primary">Read the ledger</a>
        <a href="/who-pays-us/" class="btn btn-ghost">See who pays us &rarr;</a>
      </div>

      <!-- The tally. -->
      <div class="mt-14 card overflow-hidden">
        <dl class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6">
          {tally.map(t => (
            <div class="px-5 py-6 border-b lg:border-b-0 border-r" style="border-color: var(--line);">
              <dd class="data text-3xl font-semibold mb-2" style="color: var(--text);">{String(t.count).padStart(2, '0')}</dd>
              <dt><GradeBadge grade={t.grade} small={true} /></dt>
            </div>
          ))}
        </dl>
      </div>
      <p class="mt-3 data text-[0.72rem]" style="color: var(--muted);">
        {claims.length} claims graded. Every grade links to its primary source. Disagree with one? The method is
        <a class="link" href="/methodology/">published</a>, so you can check us.
      </p>

      <p class="mt-6 text-[1rem]" style="color: var(--text-soft);">
        We turned this into a study nobody else runs. Of {claims.length} of the field's most-repeated statistics,
        <strong style="color: var(--text);">only {survivesPct}% survive a check against their own primary source.</strong>
        <a class="link font-semibold ml-1" href="/reproduction/">Read the reproduction study &rarr;</a>
      </p>
    </div>
  </section>

  <!-- Show, don't tell: the single most-quoted stat in the field, graded. -->
  <section class="wrap pb-20">
    <div class="rule pt-10">
      <h2 class="font-display text-[1.8rem] font-bold mb-2">Start with the number everybody quotes</h2>
      <p class="max-w-[62ch] mb-8" style="color: var(--text-soft);">
        If you have read anything about generative engine optimisation, you have met the 40% figure.
        It comes from a real, peer-reviewed paper. It does not mean what the marketing pages say it means.
      </p>
      {featured && (
        <div class="max-w-[46rem] fade-up">
          <ClaimCard claim={featured} />
        </div>
      )}
      <p class="mt-6 text-[0.95rem]">
        <a class="link font-semibold" href="/the-40-percent-claim/">Read the full anatomy of the 40% claim &rarr;</a>
      </p>
    </div>
  </section>

  <!-- The disclosure. This is the trust asset and it sits high, not buried in a footer. -->
  <section class="border-t border-b" style="border-color: var(--line-strong); background: var(--bg-2);">
    <div class="wrap py-16">
      <p class="data text-[0.65rem] uppercase tracking-[0.18em] mb-4" style="color: var(--muted);">The conflict, stated up front</p>
      <h2 class="font-display text-[1.9rem] sm:text-[2.3rem] font-bold max-w-[24ch] mb-6">
        Some of the best tools in this field cannot pay us a penny.
      </h2>
      <p class="max-w-[64ch] mb-9" style="color: var(--text-soft);">
        Ahrefs closed its affiliate programme in 2019. Screaming Frog has never run one. Profound, the
        category leader, publishes no payout at all. Meanwhile Nightwatch pays
        <span class="data">30%</span> for the lifetime of every customer we send, on a
        <span class="data">365-day</span> cookie. Every listicle you have read about AI visibility tools
        was written by someone facing that arithmetic. Most of them do not mention it.
      </p>

      <div class="table-scroll border" style="border-color: var(--line-strong); background: var(--surface);">
        <table class="ledger-table !my-0">
          <caption class="sr-only">What the tools we review pay GEOoptimised</caption>
          <thead>
            <tr>
              <th scope="col">Tool</th>
              <th scope="col">What it pays us</th>
              <th scope="col">Model</th>
              <th scope="col">Are we enrolled?</th>
            </tr>
          </thead>
          <tbody>
            {[...payers.slice(0, 2), ...nonPayers.slice(0, 3)].map(t => (
              <tr>
                <td class="!font-semibold !text-[0.95rem]" style="color: var(--text);">{t.name}</td>
                <td class="data" style={`color: ${t.affiliate.hasProgram ? 'var(--text)' : 'var(--g-verified)'}`}>
                  {t.affiliate.hasProgram ? t.affiliate.rate : 'NOTHING'}
                </td>
                <td class="data text-[0.82rem]">{t.affiliate.model}</td>
                <td class="data text-[0.82rem]" style="color: var(--muted);">No</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="mt-6 text-[0.95rem]" style="color: var(--text-soft);">
        {enrolled === 0
          ? 'As of today we are enrolled in none of them, so nothing on this site earns us anything. That will change, and when it does the table above will say so on the same day.'
          : `We are enrolled in ${enrolled} of them. Each is named, with its exact terms.`}
        <a class="link font-semibold ml-1" href="/who-pays-us/">The full table, all {toolsData.tools.length} tools &rarr;</a>
      </p>
    </div>
  </section>

  <!-- Humility as evidence. We publish our own failure before anyone else's. -->
  <section class="wrap py-20">
    <div class="grid gap-10 lg:grid-cols-[1.05fr_1fr] lg:gap-16 items-start">
      <div>
        <p class="data text-[0.65rem] uppercase tracking-[0.18em] mb-4" style="color: var(--muted);">Correction 001</p>
        <h2 class="font-display text-[1.9rem] sm:text-[2.2rem] font-bold mb-5 max-w-[20ch]">
          The first error in the ledger is ours.
        </h2>
        <p class="mb-4" style="color: var(--text-soft);">{ourError.lesson}</p>
        <p class="text-[0.95rem]">
          <a class="link font-semibold" href="/corrections/">Every correction we have ever made &rarr;</a>
        </p>
      </div>

      <div class="border p-6" style="border-color: var(--line-strong); background: var(--surface);">
        <p class="data text-[0.62rem] uppercase tracking-[0.14em] mb-2" style="color: var(--g-untraceable);">We said</p>
        <p class="mb-5 text-[0.95rem]" style="color: var(--text-soft);">{ourError.weSaid}</p>
        <div class="rule pt-5">
          <p class="data text-[0.62rem] uppercase tracking-[0.14em] mb-2" style="color: var(--g-verified);">Actually true</p>
          <p class="text-[0.95rem]" style="color: var(--text-soft);">{ourError.actuallyTrue}</p>
        </div>
        <p class="data text-[0.7rem] mt-5 pt-4 rule" style="color: var(--muted);">Logged {ourError.date}</p>
      </div>
    </div>
  </section>

  <!-- What this is, stated by exclusion. Fastest way to be believed. -->
  <section class="wrap pb-24">
    <div class="rule pt-12 grid gap-10 md:grid-cols-2 md:gap-16">
      <div>
        <h2 class="font-display text-[1.6rem] font-bold mb-5">What this site is not</h2>
        <ul class="space-y-3 text-[0.98rem]" style="color: var(--text-soft);">
          <li><strong style="color: var(--text);">Not an agency.</strong> We sell no GEO services. There is nothing to book.</li>
          <li><strong style="color: var(--text);">Not a tool vendor.</strong> We have no dashboard to defend and no subscription to protect.</li>
          <li><strong style="color: var(--text);">Not ad-funded.</strong> No display advertising, now or later.</li>
          <li><strong style="color: var(--text);">Not quiet about the conflict.</strong> Where we do earn a commission, we say so on the page, in the row, every time.</li>
        </ul>
      </div>
      <div>
        <h2 class="font-display text-[1.6rem] font-bold mb-5">Start here</h2>
        <ul class="space-y-3 text-[0.98rem]">
          <li><a class="link" href="/evidence/">The evidence ledger</a><span style="color: var(--muted);">: {claims.length} claims, graded against their primary sources</span></li>
          <li><a class="link" href="/generative-engine-optimisation/">What generative engine optimisation actually is</a><span style="color: var(--muted);">, and what it is not</span></li>
          <li><a class="link" href="/is-geo-a-scam/">Is GEO a scam?</a><span style="color: var(--muted);"> The sceptics, steelmanned, with names attached</span></li>
          <li><a class="link" href="/tools/">Tools, with verified pricing</a><span style="color: var(--muted);">, including the ones that publish none</span></li>
          <li><a class="link" href="/methodology/">How we grade</a><span style="color: var(--muted);">, so you can check our work</span></li>
          <li><a class="link" href="/how-to-be-found-in-ai-search/">How to be found in AI search</a><span style="color: var(--muted);">: what is evidenced, what is guessed, what is refuted</span></li>
          <li><a class="link" href="/uk-law-firms-ai-crawler-index/">The UK law firms AI crawler index</a><span style="color: var(--muted);">: 50 firms, every robots.txt read and archived</span></li>
          <li><a class="link" href="/ai-visibility-tools-compared/">Every AI visibility tool compared</a><span style="color: var(--muted);">, with what each one pays us</span></li>
        </ul>
      </div>
    </div>
  </section>
</Base>
