  description,
  url: 'https://geooptimised.com/geo-for-wordpress/',
  image: 'https://geooptimised.com/og-image.png',
  inLanguage: 'en-GB',
  datePublished: '2026-06-07',
  dateModified: '2026-06-07',
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': 'https://geooptimised.com/geo-for-wordpress/',
  },
  author: { '@id': 'https://geooptimised.com/#organization' },
  publisher: { '@id': 'https://geooptimised.com/#organization' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Which WordPress plugin is best for GEO and AI optimisation?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yoast SEO Premium and Rank Math Pro are the two most capable WordPress plugins for GEO-adjacent structured data. Rank Math Pro has a slight edge for GEO purposes due to its granular schema builder, which allows custom Article, FAQPage, HowTo, and Organization blocks without custom code. For sites that need maximum schema flexibility — multiple schema types per page, custom @graph blocks — a dedicated plugin such as WP Schema Pro or Schema Pro by Brainstorm Force provides more control than either Yoast or Rank Math.',
      },
    },
    {
      '@type': 'Question',
      name: 'How do I add llms.txt to a WordPress site?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The simplest method is to upload an llms.txt file directly to your WordPress root directory via FTP, SFTP, or your hosting control panel\'s file manager. The file should be placed at the same level as wp-config.php, making it accessible at yourdomain.com/llms.txt. Alternatively, create a custom WordPress rewrite rule in your .htaccess file to serve a dynamically generated llms.txt from a WordPress endpoint. The static file method is simpler and more reliable for most sites.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does WordPress Gutenberg help or hinder AI optimisation?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Gutenberg (the WordPress block editor) neither helps nor hinders AI optimisation directly — the semantic structure of your published HTML is what matters, and Gutenberg produces clean heading hierarchies and paragraph structure by default. Where Gutenberg helps is in enabling block patterns that encourage consistent content structure: FAQ blocks, callout blocks, and table blocks all produce AI-friendly HTML when implemented correctly. The most important GEO-related Gutenberg extension is a FAQ block that auto-generates FAQPage schema from the block content.',
      },
    },
    {
      '@type': 'Question',
      name: 'Should I block AI crawlers on WordPress?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No, unless you have a specific legal or commercial reason to do so. Blocking AI crawlers — GPTBot, ClaudeBot, PerplexityBot, Google-Extended — prevents your content from being included in retrieval-augmented generation pipelines, which means your site will not be cited in AI-generated answers. Many WordPress sites inadvertently block these bots through overly broad robots.txt rules added during plugin installations. Audit your robots.txt at yourdomain.com/robots.txt and remove any Disallow rules targeting AI crawlers you want to permit.',
      },
    },
    {
      '@type': 'Question',
      name: 'How does WordPress multisite affect GEO?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'WordPress multisite introduces entity ambiguity for AI engines: if subdomains or subdirectory sites share a root domain but serve different brands or topics, structured data must clearly differentiate each site\'s Organization entity using distinct @id values, separate sameAs arrays, and per-site canonical URLs. Schema plugins configured at the network level often produce incorrect publisher @id values on sub-sites. Audit each site\'s Organization schema individually and ensure the @id for each site resolves to a unique URL within the multisite installation.',
      },
    },
  ],
};

const breadcrumbSchema = {
