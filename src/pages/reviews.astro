    icon: `<svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>`,
  },
  {
    title: 'GEO Tools Comparison',
    slug: '/geo-tools-comparison/',
    tag: 'Side-by-side',
    desc: 'A structured framework for comparing GEO tools across consistent dimensions — useful for teams evaluating multiple platforms simultaneously.',
    icon: `<svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="21" y1="6" x2="3" y2="6"/><line x1="15" y1="12" x2="3" y2="12"/><line x1="17" y1="18" x2="3" y2="18"/></svg>`,
  },
  {
    title: 'Semrush for GEO',
    slug: '/semrush-geo/',
    tag: 'Platform Review',
    desc: 'Which Semrush features genuinely support a GEO workflow — and which are primarily built for traditional SEO with AI branding applied.',
    icon: `<svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>`,
  },
  {
    title: 'Ahrefs for GEO',
    slug: '/ahrefs-geo/',
    tag: 'Platform Review',
    desc: "Ahrefs Brand Radar, AI features, and content gap tools in a GEO context — what's useful, what's limited, and what's missing entirely.",
    icon: `<svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>`,
