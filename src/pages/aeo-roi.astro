  }
];

const faqs = [
  {
    q: 'What does AEO ROI mean?',
    a: 'AEO ROI refers to the return on investment generated by Answer Engine Optimisation. Because AI search does not produce a standard click-through event, ROI is measured through a combination of leading indicators (citation frequency, brand mention accuracy, share of voice) and lagging indicators (branded search uplift, direct traffic, and pipeline attribution from prospects who mention AI search as a discovery channel).'
  },
  {
    q: 'Why is AEO harder to attribute than SEO?',
    a: 'AEO is harder to attribute because the primary value delivery happens inside an AI engine interface with no trackable click or session. The user may act on that mention hours or days later through direct navigation or branded search, creating a gap between the citation event and any observable website interaction. Standard analytics cannot bridge this gap without additional instrumentation.'
  },
  {
    q: 'What are the leading indicators for AEO ROI?',
