---
import Base from '../layouts/Base.astro';

const title = 'Answer Engine Optimisation Agency | AEO Specialists';
const description = 'GEOoptimised is a specialist answer engine optimisation agency. We optimise your content for featured snippets, AI overviews, voice search and direct answers across every answer engine.';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "GEOoptimised",
    "url": "https://geooptimised.com/aeo-agency/",
    "description": "Specialist answer engine optimisation agency helping brands earn featured snippets, AI overview citations, voice search results and direct answers.",
    "serviceType": "Answer Engine Optimisation",
    "areaServed": "GB",
    "provider": {
      "@type": "Organization",
      "name": "GEOoptimised",
      "url": "https://geooptimised.com"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://geooptimised.com/" },
      { "@type": "ListItem", "position": 2, "name": "GEO Services", "item": "https://geooptimised.com/geo-services/" },
      { "@type": "ListItem", "position": 3, "name": "AEO Agency", "item": "https://geooptimised.com/aeo-agency/" }
    ]
  }
];

const services = [
  {
    title: 'Featured Snippet Optimisation',
    text: 'We structure your content to win paragraph, list and table snippets for the queries that drive revenue. Every snippet is an answer engine citing your brand above the fold.'
  },
  {
    title: 'FAQ Schema Implementation',
    text: 'We deploy FAQPage structured data that surfaces your answers directly in search results and feeds them into AI overviews, voice assistants and knowledge panels.'
  },
  {
    title: 'Direct Answer Formatting',
    text: 'We rewrite and restructure content so that answer engines can extract a clean, definitive response. Concise definitions, numbered steps and comparison tables — formatted for machine consumption.'
  },
  {
    title: 'AI Overview Optimisation',
    text: 'Google AI Overviews pull from a narrow set of sources. We ensure your pages meet the retrieval criteria: topical depth, entity clarity, structured data and factual specificity.'
  },
  {
    title: 'Voice Search Readiness',
    text: 'When Alexa, Siri or Google Assistant reads a single answer aloud, that answer needs to be yours. We optimise for the conversational, question-based queries that voice devices prioritise.'
  }
];

const audiences = [
  {
    title: 'SaaS and Technology Companies',
    text: 'Technical queries generate heavy AI overview coverage. If your product solves a problem that users ask about in natural language, AEO puts your brand in the answer.'
  },
  {
    title: 'Professional Services Firms',
    text: 'Legal, financial and consulting firms compete on expertise. Featured snippets and direct answers position your firm as the authoritative source before a prospect ever visits your site.'
  },
  {
    title: 'E-commerce Brands',
    text: 'Product comparison queries, sizing guides and specification lookups are prime answer engine territory. AEO captures buying intent at the moment it surfaces.'
  },
  {
    title: 'Healthcare and Wellness',
    text: 'YMYL queries demand trust signals. Answer engines favour content from recognised authorities with clear sourcing, structured data and demonstrable expertise.'
  }
];

const steps = [
  { num: '01', title: 'Answer Landscape Audit', text: 'We map every answer engine result for your target queries — featured snippets, AI overviews, People Also Ask, voice responses — and identify where your brand is absent.' },
  { num: '02', title: 'Content Restructuring', text: 'We reformat existing content into answer-ready structures: concise definitions, ordered lists, comparison tables and FAQ blocks that answer engines can parse and cite.' },
  { num: '03', title: 'Schema and Entity Markup', text: 'We implement FAQPage, HowTo, Article and organisation schema so that answer engines can identify your content type, authorship and topical relevance programmatically.' },
  { num: '04', title: 'Monitoring and Iteration', text: 'We track snippet ownership, AI overview citations and voice search appearances weekly. When a competitor displaces your answer, we respond within the same cycle.' }
];
---

<Base title={title} description={description} schema={schema} ogType="website">

  <!-- Breadcrumb -->
  <nav class="mx-auto max-w-6xl px-4 pt-6" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2 text-sm text-gray-500">
      <li><a href="/" class="transition hover:text-accent-400">Home</a></li>
      <li class="before:content-['/'] before:mx-2"><a href="/geo-services/" class="transition hover:text-accent-400">GEO Services</a></li>
      <li class="before:content-['/'] before:mx-2 text-gray-300">AEO Agency</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="relative overflow-hidden py-24 sm:py-32">
    <div class="absolute inset-0 bg-gradient-to-b from-accent-500/5 via-transparent to-transparent"></div>
    <div class="relative mx-auto max-w-4xl px-4 text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        Answer Engine Optimisation <span class="text-accent-500">Agency</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-300 sm:text-xl">
        An answer engine optimisation agency makes your brand the source that search engines, AI overviews and voice assistants cite when users ask a direct question. GEOoptimised is that agency. We engineer your content to appear as the definitive answer — not a ranked link, but the answer itself.
      </p>
    </div>
  </section>

  <!-- What an AEO Agency Does -->
  <section class="py-20">
    <div class="mx-auto max-w-4xl px-4">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">What an AEO Agency Does</h2>
      <div class="mt-8 space-y-5 text-gray-300 leading-relaxed">
        <p>
          <strong class="text-white">Answer engine optimisation is the practice of structuring content so that answer engines select it as their cited source.</strong> Answer engines include Google featured snippets, Google AI Overviews, ChatGPT, Perplexity, Gemini, Alexa and Siri. Each retrieves content differently, but they share a common requirement: the source must provide a clear, well-structured, factually specific answer to the query.
        </p>
        <p>
          Most websites are built for human readers browsing a list of results. An answer engine optimisation agency restructures that content for a different interface — one where a single synthesised response replaces the traditional results page. If your content is not formatted for extraction, it will not be cited, regardless of its quality or authority.
        </p>
        <p>
          At GEOoptimised, <a href="/answer-engine-optimisation/" class="text-accent-400 underline decoration-accent-500/30 underline-offset-2 transition hover:decoration-accent-400">answer engine optimisation</a> is a core discipline, not an add-on. We audit your current answer engine visibility, restructure content for citation, implement the schema that answer engines rely on and monitor results across every platform.
        </p>
      </div>
    </div>
  </section>

  <!-- AEO Services -->
  <section class="py-20 border-t border-geo-800/40">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="text-center text-3xl font-bold text-white sm:text-4xl">AEO Services We Deliver</h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-gray-400">
        Every deliverable is designed around a single objective: making your content the answer that gets cited.
      </p>
      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {services.map(service => (
          <div class="rounded-xl border border-geo-800/60 bg-geo-900/40 p-6">
            <h3 class="text-base font-semibold text-accent-400">{service.title}</h3>
            <p class="mt-3 text-sm text-gray-400 leading-relaxed">{service.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AEO vs GEO -->
  <section class="py-20 border-t border-geo-800/40">
    <div class="mx-auto max-w-4xl px-4">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">AEO Agency vs GEO Agency</h2>
      <div class="mt-8 space-y-5 text-gray-300 leading-relaxed">
        <p>
          <strong class="text-white">Answer engine optimisation is a subset of <a href="/generative-engine-optimisation/" class="text-accent-400 underline decoration-accent-500/30 underline-offset-2 transition hover:decoration-accent-400">generative engine optimisation</a>.</strong> AEO focuses on the answer layer — featured snippets, People Also Ask boxes, voice search responses and direct answer panels. GEO encompasses AEO but extends further into generative AI platforms like ChatGPT, Perplexity and Gemini, where the output is a synthesised narrative rather than a single extracted answer.
        </p>
        <p>
          The distinction matters because the optimisation techniques differ. AEO prioritises concise, extractable formatting — definitions, numbered lists, comparison tables. GEO requires deeper topical authority, entity relationships and citation signals that LLMs evaluate during retrieval-augmented generation. A page optimised purely for AEO may win a featured snippet but fail to appear in a ChatGPT response.
        </p>
        <p>
          GEOoptimised operates as both an AEO agency and a <a href="/geo-agency/" class="text-accent-400 underline decoration-accent-500/30 underline-offset-2 transition hover:decoration-accent-400">GEO agency</a>. We treat AEO as the foundation — if your content cannot win a featured snippet, it is unlikely to be cited by a generative model — and layer GEO strategy on top. The result is visibility across both traditional answer engines and the generative platforms that are rapidly replacing them.
        </p>
      </div>
    </div>
  </section>

  <!-- Who Needs an AEO Agency -->
  <section class="py-20 border-t border-geo-800/40">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="text-center text-3xl font-bold text-white sm:text-4xl">Who Needs an AEO Agency</h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-gray-400">
        Any business whose customers ask questions before they buy. If your audience searches with "what", "how", "best" or "vs", answer engines are already shaping their decisions.
      </p>
      <div class="mt-14 grid gap-6 sm:grid-cols-2">
        {audiences.map(audience => (
          <div class="rounded-xl border border-geo-800/40 bg-geo-900/30 p-6">
            <h3 class="text-base font-semibold text-accent-400">{audience.title}</h3>
            <p class="mt-3 text-sm text-gray-400 leading-relaxed">{audience.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our AEO Process -->
  <section class="py-20 border-t border-geo-800/40">
    <div class="mx-auto max-w-4xl px-4">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Our AEO Process</h2>
      <p class="mt-4 text-gray-400">
        A four-stage methodology that moves your content from invisible to cited.
      </p>
      <div class="mt-12 space-y-8">
        {steps.map(step => (
          <div class="flex gap-5">
            <span class="shrink-0 text-2xl font-extrabold text-accent-500/40">{step.num}</span>
            <div>
              <h3 class="text-base font-semibold text-white">{step.title}</h3>
              <p class="mt-2 text-sm text-gray-400 leading-relaxed">{step.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 border-t border-geo-800/40">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Start Winning Answers</h2>
      <p class="mx-auto mt-5 max-w-xl text-gray-300">
        Your competitors are already being cited by answer engines. We will audit your current visibility, identify the highest-value queries you are missing and build the content strategy that puts your brand in the answer. No retainer commitment required for the initial audit.
      </p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact/" class="inline-flex items-center rounded-lg bg-accent-500 px-8 py-3.5 text-sm font-semibold text-geo-950 shadow-lg shadow-accent-500/20 transition hover:bg-accent-400 hover:shadow-accent-400/30">
          Get Your AEO Audit
        </a>
        <a href="/geo-services/" class="inline-flex items-center rounded-lg border border-geo-600 px-6 py-3 text-sm font-semibold text-gray-200 transition hover:border-accent-500 hover:text-white">
          View All Services
        </a>
      </div>
    </div>
  </section>

</Base>
