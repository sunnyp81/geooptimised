      "@type": "Organization",
      "name": "GEOoptimised",
      "url": "https://geooptimised.com",
      "logo": "https://geooptimised.com/icon-512.png"
    },
    "datePublished": "2026-06-06",
    "dateModified": "2026-06-06",
    "url": "https://geooptimised.com/geo-companies/",
