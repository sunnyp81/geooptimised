---
import tools from '../data/tools.json';
const year = new Date().getFullYear();
const enrolled = tools.tools.filter((t: any) => t.ourEnrolment === 'enrolled').length;

const groups = [
  {
    title: 'The ledger',
    links: [
      { label: 'Evidence ledger', href: '/evidence/' },
      { label: 'The reproduction study', href: '/reproduction/' },
      { label: 'Corrections', href: '/corrections/' },
      { label: 'How we grade', href: '/methodology/' },
    ],
  },
  {
    title: 'Reference',
    links: [
      { label: 'Generative engine optimisation', href: '/generative-engine-optimisation/' },
      { label: 'The 40% claim', href: '/the-40-percent-claim/' },
      { label: 'The grounding clause', href: '/the-grounding-clause/' },
      { label: 'Is GEO a scam?', href: '/is-geo-a-scam/' },
    ],
  },
  {
    title: 'Tools',
    links: [
      { label: 'Verified pricing and payouts', href: '/tools/' },
      { label: 'Who pays us', href: '/who-pays-us/' },
    ],
  },
  {
    title: 'Site',
    links: [
      { label: 'About', href: '/about/' },
      { label: 'Contact', href: '/contact/' },
    ],
  },
];
---
<footer class="mt-24 border-t" style="border-color: var(--line); background: var(--bg-2);">
  <div class="wrap py-14">
    <!-- The disclosure sits above the sitemap. It is the most important thing in the footer. -->
    <div class="border p-5 mb-12" style="border-color: var(--line-strong); background: var(--surface);">
      <p class="data text-[0.62rem] uppercase tracking-[0.14em] mb-2" style="color: var(--muted);">Standing disclosure</p>
      <p class="text-[0.95rem]" style="color: var(--text-soft);">
        {enrolled === 0 ? (
          <>GEOoptimised is currently enrolled in <strong style="color: var(--text);">no affiliate programme</strong>. We earn nothing if you buy any tool named on this site. When that changes, this line changes with it, and every affected row on <a class="link" href="/who-pays-us/">who pays us</a> updates the same day.</>
        ) : (
          <>GEOoptimised earns a commission from <strong style="color: var(--text);">{enrolled}</strong> of the tools it reviews. Every one is named on <a class="link" href="/who-pays-us/">who pays us</a>, alongside the ones that pay us nothing.</>
        )}
      </p>
    </div>

    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      {groups.map(g => (
        <div>
          <p class="data text-[0.62rem] uppercase tracking-[0.14em] mb-3" style="color: var(--muted);">{g.title}</p>
          <ul class="space-y-2">
            {g.links.map(l => (
              <li><a href={l.href} class="text-[0.9rem]" style="color: var(--text-soft);">{l.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="rule mt-12 pt-6 flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
      <p class="text-[0.82rem]" style="color: var(--muted);">
        &copy; {year} GEOoptimised. Written by Sunny Patel. British English throughout.
      </p>
      <p class="data text-[0.72rem]" style="color: var(--muted);">
        Every claim graded. Every source named. Every correction kept.
      </p>
    </div>
  </div>
</footer>
