                <td class="px-4 py-3 text-green-400">Yes (rule-based)</td>
                <td class="px-4 py-3 text-green-400">Full control</td>
              </tr>
              <tr class="hover:bg-geo-900/50 transition">
                <td class="px-4 py-3 text-ink-200 font-semibold">Schema Pro (Brainstorm)</td>
                <td class="px-4 py-3 text-green-400">Yes</td>
                <td class="px-4 py-3 text-green-400">Yes</td>
                <td class="px-4 py-3 text-yellow-400">Partial</td>
                <td class="px-4 py-3 text-green-400">Yes</td>
              </tr>
              <tr class="hover:bg-geo-900/50 transition">
                <td class="px-4 py-3 text-ink-200 font-semibold">All in One SEO</td>
                <td class="px-4 py-3 text-green-400">Yes</td>
                <td class="px-4 py-3 text-yellow-400">FAQ only</td>
                <td class="px-4 py-3 text-yellow-400">Limited</td>
