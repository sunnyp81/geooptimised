const description = 'How to model and attribute ROI for AEO and GEO: leading vs lagging indicators, honest attribution challenges, and a framework for measuring AI search returns.';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: 'AEO ROI: Measuring Answer Engine Returns',
    description: 'How to model and attribute ROI for AEO and GEO: leading vs lagging indicators, honest attribution challenges, and a framework for measuring AI search returns.',
    url: 'https://geooptimised.com/aeo-roi/',
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': 'https://geooptimised.com/aeo-roi/'
    },
    author: { '@id': 'https://geooptimised.com/#organization' },
    publisher: { '@id': 'https://geooptimised.com/#organization' },
