---
import Base from '../layouts/Base.astro';

const title = 'GEO Audit: Assessing AI Visibility Readiness | GEOoptimised';
const description = 'A complete GEO audit framework covering entity clarity, schema coverage, content extractability, and citation baseline — with a step-by-step process and DIY audit table.';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'How to Conduct a GEO Audit',
    description: 'A step-by-step framework for auditing AI visibility readiness across entity signals, schema coverage, content extractability, and citation baseline.',
    url: 'https://geooptimised.com/geo-audit/',
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': 'https://geooptimised.com/geo-audit/'
    },
    image: 'https://geooptimised.com/og-image.png',
    datePublished: '2026-06-07',
    dateModified: '2026-06-07',
    inLanguage: 'en-GB',
    author: { '@id': 'https://geooptimised.com/#organization' },
    publisher: { '@id': 'https://geooptimised.com/#organization' },
    step: [
      {
        '@type': 'HowToStep',
        position: 1,
        name: 'Establish your citation baseline',
        text: 'Run a fixed set of 10–15 target queries across ChatGPT, Perplexity, Gemini, Copilot, and Google AI Overviews. Log whether your brand is cited, the accuracy of any description, and which competitors appear.'
      },
      {
        '@type': 'HowToStep',
        position: 2,
        name: 'Audit entity clarity and consistency',
        text: 'Compare your brand name, category, description, founding date, and contact details across your website, Google Business Profile, Wikidata, LinkedIn, and any structured data. Flag every inconsistency.'
      },
      {
        '@type': 'HowToStep',
        position: 3,
        name: 'Review schema coverage',
        text: 'Crawl or manually inspect every content page for Article/TechArticle, FAQPage, BreadcrumbList, and Organization schema. Validate each with Google\'s Rich Results Test. Note any pages missing required types.'
      },
      {
        '@type': 'HowToStep',
        position: 4,
        name: 'Assess content extractability',
        text: 'Read the opening paragraph of each priority page. If it does not answer the primary query in the first sentence, mark it as failing. Check paragraph length, heading style, and presence of FAQ sections and tables.'
      },
      {
        '@type': 'HowToStep',
        position: 5,
        name: 'Check technical AI accessibility',
        text: 'Review robots.txt for AI crawler blocks. Confirm llms.txt exists at the domain root. Verify Core Web Vitals pass thresholds (LCP < 2.5 s, CLS < 0.1). Check that all priority pages are indexed.'
      },
      {
        '@type': 'HowToStep',
        position: 6,
        name: 'Compile findings and prioritise remediation',
        text: 'Score each audit dimension, identify the two or three highest-impact gaps, and build a remediation backlog ordered by citation impact. Schedule entity and technical fixes before content improvements.'
      }
    ]
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is a GEO audit?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'A GEO audit is a structured assessment of a website\'s readiness to earn citations in AI-generated answers. It evaluates four dimensions: entity clarity (how consistently and unambiguously the brand is described across the web), schema coverage (whether structured data correctly labels content for AI retrieval systems), content extractability (whether pages are written so that AI models can cleanly pull and cite relevant passages), and citation baseline (how often and how accurately the brand currently appears in responses from ChatGPT, Perplexity, Gemini, Copilot, and Google AI Overviews).'
        }
      },
      {
        '@type': 'Question',
        name: 'How is a GEO audit different from an SEO audit?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'A GEO audit differs from a traditional SEO audit in its focus and metrics. An SEO audit assesses crawlability, keyword targeting, backlink profiles, and on-page optimisation for ranking algorithms. A GEO audit assesses entity consistency, schema type coverage, extraction-friendly content structure, and AI crawler access — signals that determine whether content is cited in AI-generated answers rather than ranked in blue-link results. The two audits share some technical overlap (canonicals, Core Web Vitals, indexation) but diverge significantly in content and entity assessment.'
        }
      },
      {
        '@type': 'Question',
        name: 'How long does a GEO audit take?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'A GEO audit of a medium-sized site (50–200 pages) typically takes five to ten business days when conducted professionally. The citation baseline phase takes one to two days of query logging across five platforms. Entity and schema review takes one to two days. Content extractability assessment takes two to four days depending on content volume. Technical checks take half a day. A DIY GEO audit using this framework can be completed in two to three weeks at part-time effort, with the content assessment stage being the most time-intensive component.'
        }
      },
      {
        '@type': 'Question',
        name: 'What does a GEO audit deliverable look like?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'A professional GEO audit deliverable includes: a citation baseline report documenting current visibility across five AI platforms; an entity consistency matrix flagging all attribute discrepancies; a schema coverage audit listing every page with missing or invalid structured data; a content extractability scorecard rating each priority page across five criteria; a prioritised remediation backlog ordered by estimated citation impact; and a 90-day implementation roadmap. The output is diagnostic and prescriptive — it tells you exactly what to fix and in what order.'
        }
      },
      {
        '@type': 'Question',
        name: 'Which AI platforms should a GEO audit cover?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'A complete GEO audit should cover all five major generative platforms: ChatGPT, Perplexity, Google Gemini, Microsoft Copilot, and Google AI Overviews. Each platform retrieves and cites sources through different mechanisms. Perplexity uses live RAG retrieval. ChatGPT blends training data with optional browsing. Google AI Overviews correlates with organic authority and Knowledge Graph signals. Auditing all five gives you a cross-platform citation map and reveals which platforms your content performs best on — and which represent the largest improvement opportunity.'
        }
      },
      {
        '@type': 'Question',
        name: 'What should I fix first after a GEO audit?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'After a GEO audit, fix issues in dependency order: first, technical access (robots.txt AI crawler blocks, if any); second, entity consistency (attribute mismatches across Google Business Profile, Wikidata, and your website); third, schema coverage (missing Article, FAQPage, and BreadcrumbList schema on priority pages); fourth, content extractability (rewriting opening paragraphs to definitional statements on your highest-traffic pages). Do not start content improvements until entity and technical foundations are in place — content optimisation earns fewer citations when the underlying entity is ambiguous.'
        }
      }
    ]
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://geooptimised.com/' },
      { '@type': 'ListItem', position: 2, name: 'GEO Tracking & Monitoring', item: 'https://geooptimised.com/geo-monitoring/' },
      { '@type': 'ListItem', position: 3, name: 'GEO Audit', item: 'https://geooptimised.com/geo-audit/' }
    ]
