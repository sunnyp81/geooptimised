---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: object | object[];
  ogType?: string;
}

const { title, description, canonical, schema, ogType = 'website' } = Astro.props;
const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site ?? 'https://geooptimised.com').href;
const siteName = 'GEOoptimised';
---
<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="theme-color" content="#0A0F1E" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={siteName} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;450;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
    rel="stylesheet"
  />
  {schema && (
    Array.isArray(schema)
      ? schema.map(s => <script type="application/ld+json" set:html={JSON.stringify(s)} />)
      : <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}
    <!-- GA4, consent-gated: loaded only after an explicit accept via the banner below. See /privacy/. -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      window.__loadAnalytics = function () {
        if (window.__analyticsLoaded) return;
        window.__analyticsLoaded = true;
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-8XDLBZ372Q';
        document.head.appendChild(s);
        gtag('js', new Date());
        gtag('config', 'G-8XDLBZ372Q');
      };
      if (localStorage.getItem('cookie-consent') === 'accepted') {
        window.__loadAnalytics();
      }
    </script>
  </head>
<body>
  <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 btn btn-primary">Skip to content</a>
  <Header />
  <main id="main">
    <slot />
  </main>
  <div id="cookie-banner" hidden class="fixed inset-x-0 bottom-0 z-50 border-t" style="border-color: var(--line-strong); background: var(--bg-2);">
    <div class="wrap py-4 flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
      <p class="text-[0.85rem] max-w-[52ch]" style="color: var(--text-soft);">
        We use Google Analytics to see which pages get read. It only runs if you accept.
        <a class="link" href="/privacy/">Privacy</a>.
      </p>
      <div class="flex gap-3 shrink-0">
        <button id="cookie-reject" class="btn btn-ghost text-[0.85rem]">Necessary only</button>
        <button id="cookie-accept" class="btn btn-primary text-[0.85rem]">Accept analytics</button>
      </div>
    </div>
  </div>
  <script is:inline>
    (function () {
      var choice = localStorage.getItem('cookie-consent');
      var banner = document.getElementById('cookie-banner');
      if (!choice && banner) {
        banner.hidden = false;
        document.getElementById('cookie-accept').addEventListener('click', function () {
          localStorage.setItem('cookie-consent', 'accepted');
          banner.hidden = true;
          window.__loadAnalytics();
        });
        document.getElementById('cookie-reject').addEventListener('click', function () {
          localStorage.setItem('cookie-consent', 'rejected');
          banner.hidden = true;
        });
      }
    })();
  </script>
  <Footer />

  <script>
    // Fade-up on scroll. Respects reduced-motion by simply revealing everything.
    const els = document.querySelectorAll<HTMLElement>('.fade-up');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce || !('IntersectionObserver' in window)) {
      els.forEach(el => el.classList.add('is-visible'));
    } else {
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('is-visible');
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
      els.forEach(el => io.observe(el));
    }
  </script>
</body>
</html>
