      <li aria-hidden="true" class="text-ink-600">/</li>
      <li class="text-ink-200" aria-current="page">Best AEO Platforms 2026</li>
    </ol>
  </nav>

  <!-- Hero -->
  <header class="hero-fade relative overflow-hidden">
    <div class="container-wide grid gap-12 pt-12 pb-20 lg:grid-cols-12 lg:items-center">
