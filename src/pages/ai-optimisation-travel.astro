                <td class="px-5 py-3 text-ink-300">Live web RAG</td>
                <td class="px-5 py-3 text-accent-400 font-semibold">Very High</td>
                <td class="px-5 py-3 text-ink-300">Allow PerplexityBot; publish itinerary and comparison content with extractable definitive statements</td>
              </tr>
              <tr class="hover:bg-geo-900/40 transition">
                <td class="px-5 py-3 text-ink-200 font-medium">ChatGPT</td>
                <td class="px-5 py-3 text-ink-300">Parametric + optional Browse</td>
                <td class="px-5 py-3 text-ink-300">High</td>
                <td class="px-5 py-3 text-ink-300">Build editorial presence in training-data-heavy publications; allow GPTBot in robots.txt</td>
              </tr>
              <tr class="hover:bg-geo-900/40 transition">
                <td class="px-5 py-3 text-ink-200 font-medium">Gemini</td>
                <td class="px-5 py-3 text-ink-300">RAG + Google Maps integration</td>
                <td class="px-5 py-3 text-ink-300">High</td>
                <td class="px-5 py-3 text-ink-300">Google Maps optimisation; review volume and recency; Google-Extended not blocked</td>
              </tr>
              <tr class="hover:bg-geo-900/40 transition">
                <td class="px-5 py-3 text-ink-200 font-medium">Bing Copilot</td>
                <td class="px-5 py-3 text-ink-300">Bing index RAG</td>
                <td class="px-5 py-3 text-ink-300">Medium</td>
                <td class="px-5 py-3 text-ink-300">Bing Webmaster Tools submission; structured content for Bing crawl priority</td>
              </tr>
            </tbody>
