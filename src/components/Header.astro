---
const navLinks = [
  { href: '/generative-engine-optimisation/', label: 'GEO Guide' },
  { href: '/geo-services/', label: 'Services' },
  { href: '/answer-engine-optimisation/', label: 'AEO' },
  { href: '/geo-agency/', label: 'Agency' },
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
];
---
<header class="sticky top-0 z-40 border-b border-geo-800/60 bg-geo-950/80 backdrop-blur-xl">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
    <a href="/" class="text-xl font-bold tracking-tight text-white">
      GEO<span class="text-accent-500">optimised</span>
    </a>
    <button id="menu-toggle" class="md:hidden text-gray-300 hover:text-white" aria-label="Toggle menu" aria-expanded="false">
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
    <ul id="nav-menu" class="hidden md:flex items-center gap-6 text-sm font-medium">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="text-gray-300 transition hover:text-accent-400">{link.label}</a>
        </li>
      ))}
    </ul>
  </nav>
  <ul id="mobile-menu" class="hidden flex-col gap-2 px-4 pb-4 text-sm font-medium md:hidden">
    {navLinks.map(link => (
      <li>
        <a href={link.href} class="block rounded-lg px-3 py-2 text-gray-300 transition hover:bg-geo-800 hover:text-white">{link.label}</a>
      </li>
    ))}
  </ul>
</header>
<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
