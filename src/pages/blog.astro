---
import Base from '../layouts/Base.astro';

const title = 'GEOoptimised Insights — GEO Guides & Resources';
const description = 'GEOoptimised Insights: curated guides to generative engine optimisation, AI brand visibility, answer engine optimisation, and GEO strategy — organised by theme.';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "GEOoptimised Insights",
    "description": "A curated hub of cornerstone guides covering generative engine optimisation, AI brand visibility, answer engine optimisation, and GEO strategy.",
    "url": "https://geooptimised.com/blog/",
    "datePublished": "2026-06-07",
    "dateModified": "2026-06-07",
    "inLanguage": "en-GB",
    "image": "https://geooptimised.com/og-image.png",
    "author": {
      "@id": "https://geooptimised.com/#organization"
    },
    "publisher": {
      "@id": "https://geooptimised.com/#organization"
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://geooptimised.com/blog/"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://geooptimised.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Generative Engine Optimisation",
        "item": "https://geooptimised.com/generative-engine-optimisation/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "GEOoptimised Insights",
        "item": "https://geooptimised.com/blog/"
      }
    ]
  }
];

const themes = [
  {
    theme: 'Foundations',
    desc: 'The core concepts every practitioner needs before building a GEO programme.',
    guides: [
      {
        title: 'Generative Engine Optimisation',
        slug: '/generative-engine-optimisation/',
        desc: 'The ROOT guide: what GEO is, why it matters, and how it differs from traditional search optimisation. Start here.',
        tag: 'ROOT Guide',
      },
      {
        title: 'What Is GEO?',
        slug: '/what-is-geo/',
        desc: 'A plain-language definition of generative engine optimisation — written to be LLM-citable and accurate.',
        tag: 'Definition',
      },
      {
        title: 'Answer Engine Optimisation',
        slug: '/answer-engine-optimisation/',
        desc: 'How AEO relates to GEO, what answer engines are, and why both disciplines matter for modern visibility strategy.',
        tag: 'Related Discipline',
      },
    ],
  },
  {
    theme: 'Strategy & Implementation',
    desc: 'How to turn GEO concepts into a structured, repeatable programme.',
    guides: [
      {
        title: 'GEO Strategy',
        slug: '/geo-strategy/',
        desc: 'A complete framework for building a prioritised GEO programme: from baseline audit to competitive positioning and ongoing iteration.',
        tag: 'Strategy',
      },
      {
        title: 'GEO Tools',
        slug: '/geo-tools/',
        desc: 'The four categories of GEO tooling, evaluation criteria, and a framework for selecting the right stack for your programme maturity.',
        tag: 'Tools',
      },
    ],
  },
  {
    theme: 'Brand Visibility in AI',
    desc: 'How to build the brand signals that make AI models recognise, trust, and cite your organisation.',
    guides: [
      {
        title: 'AI Brand Visibility',
        slug: '/ai-brand-visibility/',
        desc: 'Entity authority, knowledge graph presence, and the brand signals that determine whether AI platforms cite your organisation with confidence.',
        tag: 'Brand & Entity',
      },
    ],
  },
];
---

<Base title={title} description={description} schema={schema} canonical="https://geooptimised.com/blog/" ogType="website">

  <!-- Breadcrumb -->
  <nav aria-label="Breadcrumb" class="container-wide pt-8">
    <ol class="flex items-center gap-2 font-mono text-xs text-ink-300">
      <li><a href="/" class="hover:text-[var(--accent)] transition-colors">Home</a></li>
      <li aria-hidden="true" class="text-ink-600">/</li>
      <li><a href="/generative-engine-optimisation/" class="hover:text-[var(--accent)] transition-colors">Generative Engine Optimisation</a></li>
      <li aria-hidden="true" class="text-ink-600">/</li>
      <li class="text-ink-200" aria-current="page">GEOoptimised Insights</li>
    </ol>
  </nav>

  <!-- Hero -->
  <header class="hero-fade relative overflow-hidden">
    <div class="container-wide grid gap-12 pt-12 pb-20 lg:grid-cols-12 lg:items-center">
      <div class="lg:col-span-8">
        <span class="eyebrow">Insights Hub</span>
        <h1 class="mt-4 font-display text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
          <span class="grad-text">GEOoptimised Insights</span>
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-300">
          <strong class="text-ink-100">Every piece of content on GEOoptimised is a primary resource, not a summary of someone else's thinking.</strong> This hub organises our cornerstone guides by theme so you can navigate the discipline systematically — from foundational concepts through strategy, implementation, and the tools that make AI visibility measurable.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/generative-engine-optimisation/" class="btn btn-primary">Start with the ROOT Guide</a>
          <a href="/contact/" class="btn btn-ghost">Talk to the Team</a>
        </div>
      </div>
      <div class="lg:col-span-4">
        <div class="card p-6">
          <span class="eyebrow">What you will find</span>
          <ul class="mt-4 space-y-3 text-sm text-ink-300">
            <li class="flex items-start gap-2">
              <svg aria-hidden="true" class="mt-0.5 h-4 w-4 shrink-0 text-[var(--accent)]" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              Cornerstone GEO guides
            </li>
            <li class="flex items-start gap-2">
              <svg aria-hidden="true" class="mt-0.5 h-4 w-4 shrink-0 text-[var(--accent)]" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              Strategy frameworks
            </li>
            <li class="flex items-start gap-2">
              <svg aria-hidden="true" class="mt-0.5 h-4 w-4 shrink-0 text-[var(--accent)]" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              Tool guides and reviews
            </li>
            <li class="flex items-start gap-2">
              <svg aria-hidden="true" class="mt-0.5 h-4 w-4 shrink-0 text-[var(--accent)]" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              Brand &amp; entity resources
            </li>
          </ul>
        </div>
      </div>
    </div>
  </header>

  <!-- About This Hub -->
  <section class="container-wide py-12">
    <div class="card border-l-4 border-l-[var(--accent)] p-8 max-w-3xl">
      <span class="eyebrow">About This Hub</span>
      <h2 class="mt-3 font-display text-xl font-semibold text-ink-50">Cornerstone Guides, Not Dated Posts</h2>
      <p class="mt-3 text-ink-300 leading-relaxed">
        This is not a conventional blog with reverse-chronological posts that age out of relevance. GEOoptimised Insights is an evergreen knowledge base: each guide is written to the standard of a primary reference and updated as the discipline evolves. We do not publish placeholder content or speculative commentary. Every guide on this site represents a considered, substantive treatment of its topic. We link to the <a href="/generative-engine-optimisation/" class="text-accent-400 underline decoration-accent-500/30 underline-offset-2 hover:text-accent-300">Generative Engine Optimisation ROOT page</a> as the canonical starting point — everything else extends from there.
      </p>
    </div>
  </section>

  <!-- Themed Guide Clusters -->
  {themes.map(section => (
    <section class="container-wide py-16">
      <div class="mb-8">
        <span class="eyebrow">{section.theme}</span>
        <h2 class="mt-3 font-display text-2xl font-bold grad-text sm:text-3xl">{section.theme}</h2>
        <p class="mt-3 max-w-2xl text-ink-300 leading-relaxed">{section.desc}</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {section.guides.map(guide => (
          <a href={guide.slug} class="card card-hover block p-8 flex flex-col">
            <span class="eyebrow">{guide.tag}</span>
            <h3 class="mt-2 font-display text-xl font-semibold text-ink-50">{guide.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-ink-300 flex-1">{guide.desc}</p>
            <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-[var(--accent)]">
              Read guide <span aria-hidden="true">&rarr;</span>
            </span>
          </a>
        ))}
      </div>
    </section>
  ))}

  <!-- What GEO Content Looks Like -->
  <section class="container-wide py-20">
    <div class="prose-dark space-y-12">

      <div class="grid gap-8 lg:grid-cols-12">
        <div class="lg:col-span-5">
          <span class="eyebrow">Our Approach</span>
          <h2 id="our-approach" class="anchor-top !mt-3">What Makes GEO Content Different</h2>
        </div>
        <div class="lg:col-span-7">
          <p><strong class="text-ink-100">Content that earns AI citations is structurally and linguistically different from content that merely ranks in traditional search.</strong> GEO content makes explicit claims rather than implied ones. It uses clear attribution language. It provides specific, verifiable data points. It leads every section with a bold, quotable statement that an AI model can extract without needing the surrounding context to make sense of it.</p>
          <p>Everything published on GEOoptimised is written to those standards — not as a demonstration exercise but because it is the right way to communicate clearly. A guide that is genuinely useful to a practitioner reading it is also a guide that AI models will cite when users ask about that topic. The interests of the human reader and the AI system are aligned when content is authoritative, specific, and well-structured.</p>
          <p>This is the principle behind the <a href="/generative-engine-optimisation/" class="text-accent-400 underline decoration-accent-500/30 underline-offset-2 hover:text-accent-300">generative engine optimisation</a> discipline as we practise it. The content strategy and the AI optimisation strategy are the same strategy: produce the clearest, most authoritative treatment of each topic available anywhere, and you will earn both the trust of practitioners and the citations of AI models. There is no shortcut that separates the two outcomes — which is why content quality is always the foundation of everything else in a GEO programme.</p>
          <p>As GEOoptimised publishes new guides, this hub will be updated to reflect them. New content will be organised into the existing thematic clusters or, where a new cluster is warranted, added as a distinct section. The goal is a knowledge base that grows in depth and coherence, not in volume alone. For more on the underlying <a href="/geo-strategy/" class="text-accent-400 underline decoration-accent-500/30 underline-offset-2 hover:text-accent-300">GEO strategy</a> that informs our content decisions, the strategy guide covers the full framework.</p>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA Banner -->
  <section class="container-wide py-20">
    <div class="relative overflow-hidden rounded-2xl dot-grid">
      <div class="absolute inset-0 bg-gradient-to-br from-[rgba(var(--accent-glow),.12)] via-transparent to-transparent"></div>
      <div class="relative px-8 py-16 text-center sm:px-16">
        <span class="eyebrow">Take the Next Step</span>
        <h2 class="mt-4 font-display text-3xl font-bold text-ink-50 sm:text-4xl">From Reading to Results</h2>
        <p class="mt-4 mx-auto max-w-2xl text-ink-300 leading-relaxed">
          Our guides are written for practitioners who want to understand GEO properly, not just adopt the terminology. If you are ready to move from reading to implementation, get in touch. We offer a free, no-obligation consultation to assess your current AI visibility position and discuss where investment would have the most impact.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
          <a href="/contact/" class="btn btn-primary">Book a Consultation</a>
          <a href="/geo-services/" class="btn btn-ghost">Explore GEO Services</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Hubs -->
  <section class="container-wide py-20 border-t hair">
    <span class="eyebrow">Related</span>
    <h2 class="mt-3 font-display text-2xl font-bold text-ink-50">Start Exploring</h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-3">
      <a href="/generative-engine-optimisation/" class="card card-hover block p-6">
        <h3 class="font-display text-lg font-semibold text-ink-50">Generative Engine Optimisation</h3>
        <p class="mt-2 text-sm text-ink-300 leading-relaxed">The ROOT guide — the foundational resource for understanding GEO, its relationship to traditional SEO, and why it matters now.</p>
        <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-[var(--accent)]">Read more <span aria-hidden="true">&rarr;</span></span>
      </a>
      <a href="/geo-tools/" class="card card-hover block p-6">
        <h3 class="font-display text-lg font-semibold text-ink-50">GEO Tools</h3>
        <p class="mt-2 text-sm text-ink-300 leading-relaxed">The complete guide to AI visibility trackers, citation monitors, content optimisers, and brand authority analysers.</p>
        <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-[var(--accent)]">Read more <span aria-hidden="true">&rarr;</span></span>
      </a>
      <a href="/geo-services/" class="card card-hover block p-6">
        <h3 class="font-display text-lg font-semibold text-ink-50">GEO Services</h3>
        <p class="mt-2 text-sm text-ink-300 leading-relaxed">What a generative engine optimisation agency delivers: audits, entity work, structured data, content, and ongoing monitoring.</p>
        <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-[var(--accent)]">Read more <span aria-hidden="true">&rarr;</span></span>
      </a>
    </div>
  </section>

</Base>
