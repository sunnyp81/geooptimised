const tocItems = [
  { id: 'landscape', label: 'The GEO Landscape' },
  { id: 'what-to-look-for', label: 'What to Look For' },
  { id: 'types', label: 'Types of GEO Company' },
  { id: 'evaluation', label: 'How to Evaluate' },
  { id: 'red-flags', label: 'Red Flags' },
  { id: 'faq', label: 'FAQ' },
