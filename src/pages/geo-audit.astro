];

const tocItems = [
  { id: 'what-a-geo-audit-covers', label: 'What a GEO Audit Covers' },
  { id: 'entity-clarity', label: 'Entity Clarity' },
  { id: 'schema-coverage', label: 'Schema Coverage' },
