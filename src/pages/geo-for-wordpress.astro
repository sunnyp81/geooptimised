                <td class="px-4 py-3 text-red-400">No</td>
                <td class="px-4 py-3 text-yellow-400">Limited</td>
              </tr>
              <tr class="hover:bg-geo-900/50 transition">
                <td class="px-4 py-3 text-ink-200 font-semibold">Rank Math Pro</td>
                <td class="px-4 py-3 text-green-400">Yes (granular)</td>
                <td class="px-4 py-3 text-green-400">Both, per-post</td>
                <td class="px-4 py-3 text-green-400">Yes</td>
                <td class="px-4 py-3 text-green-400">Full control</td>
              </tr>
              <tr class="hover:bg-geo-900/50 transition">
                <td class="px-4 py-3 text-ink-200 font-semibold">WP Schema Pro</td>
