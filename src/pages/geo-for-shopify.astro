                <td class="px-4 py-3 text-ink-300">High — recommendation trust</td>
              </tr>
              <tr class="hover:bg-geo-900/50 transition">
                <td class="px-4 py-3 text-ink-200 font-mono">Product.sku / gtin</td>
                <td class="px-4 py-3 text-yellow-400">Partial</td>
                <td class="px-4 py-3 text-green-400">Yes</td>
                <td class="px-4 py-3 text-ink-300">Medium — deduplication</td>
              </tr>
