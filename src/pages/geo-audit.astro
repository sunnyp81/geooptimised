    priority: 'Critical'
  },
  {
    dimension: 'Content extractability',
    what: 'Structural suitability for AI passage extraction and citation',
    signals: 'Definitional openings, paragraph length, headings, FAQs, tables',
    sources: 'Manual content audit, extraction test queries',
    priority: 'High'
  },
  {
    dimension: 'Citation baseline',
    what: 'Current citation frequency and accuracy across AI platforms',
    signals: 'Brand mention rate, description accuracy, competitor presence',
    sources: 'ChatGPT, Perplexity, Gemini, Copilot, AI Overviews',
    priority: 'High'
  },
  {
    dimension: 'Technical AI access',
    what: 'Whether AI crawlers can reach and index your content',
    signals: 'robots.txt, llms.txt, Core Web Vitals, indexation status',
    sources: 'robots.txt inspection, GSC, Bing Webmaster Tools',
    priority: 'Critical'
  }
];

const stepByStep = [
  {
    step: 1,
    title: 'Establish Your Citation Baseline',
    detail: 'Before auditing anything on your site, document what AI engines currently say about your brand. Run 10–15 target queries across all five platforms — queries you expect your brand to appear in. Log: is your brand cited? What description is given? Is it accurate? Which competitors appear, and in which position? This baseline is your measurement anchor. Every improvement you make will be judged against it, so document it thoroughly before touching anything on your site.'
  },
  {
    step: 2,
    title: 'Audit Entity Clarity and Consistency',
    detail: 'Open five tabs: your homepage, your Google Business Profile, your Wikidata entry (search Wikidata for your brand name), your LinkedIn company page, and your Organization schema (use a JSON-LD validator on your homepage source). Compare your brand name, category descriptor, description text, founding date, location, and website URL across all five. Every discrepancy — even capitalisation differences — is an entity ambiguity signal. Compile a matrix of attribute values across sources and mark every mismatch for correction.'
  },
  {
    step: 3,
    title: 'Review Schema Coverage Across Priority Pages',
    detail: 'Define your priority pages: homepage, top five organic landing pages, and any pages targeting your core GEO queries. For each page, check: does it have Article or TechArticle schema? Does the FAQ section (if present) have FAQPage schema? Does it have BreadcrumbList schema? Run each page through Google\'s Rich Results Test. Log pass/fail for each schema type. Pages missing schema are invisible to the structured-data signals that AI retrieval systems use to assess source authority.'
  },
  {
    step: 4,
    title: 'Assess Content Extractability on Priority Pages',
    detail: 'For each priority page, read only the first sentence of the opening paragraph. Ask: does this sentence answer the primary query the page is targeting? If not, mark it as failing the extraction test. Then check: are paragraphs two to four sentences covering one point each? Are H2s declarative labels rather than questions? Is there a FAQ section with four to six questions and concise answers? Is there at least one table for comparative content? Pages that fail three or more of these criteria are your highest-priority content remediation targets.'
  },
  {
    step: 5,
    title: 'Check Technical AI Accessibility',
    detail: 'Open your robots.txt file directly (yourdomain.com/robots.txt). Search for GPTBot, PerplexityBot, ClaudeBot, Amazonbot, and Googlebot-Extended. If any are listed under Disallow, that is a blocking finding. Check that llms.txt exists at your domain root. Pull your Core Web Vitals from Google Search Console — flag any pages with LCP above 2.5 seconds or CLS above 0.1. Confirm all priority pages are in the Coverage report as "Indexed." Technical blocks are the easiest fixes in a GEO audit and should always be resolved first.'
  },
  {
    step: 6,
    title: 'Compile Findings and Prioritise Remediation',
    detail: 'Collect every finding from steps one through five into a single remediation backlog. Score each finding by estimated citation impact: technical blocks and entity inconsistencies are Critical (fix immediately, before content work begins); missing schema on priority pages is High; content extractability failures are High-Medium depending on page importance; llms.txt and CWV are Medium. Build your 90-day implementation roadmap with entity and technical fixes in the first 30 days, schema in days 30–60, and content improvements in days 60–90.'
  }
];

const diyAuditRows = [
  { area: 'Technical access', check: 'AI crawlers allowed in robots.txt', pass: 'No Disallow for GPTBot, PerplexityBot, ClaudeBot', fail: 'Any Disallow: / for AI user-agents', priority: 'Critical' },
  { area: 'Technical access', check: 'llms.txt deployed at domain root', pass: '/llms.txt returns 200 with declared purpose', fail: '404 or missing file', priority: 'High' },
  { area: 'Technical access', check: 'Core Web Vitals pass', pass: 'LCP < 2.5 s and CLS < 0.1 on priority pages', fail: 'LCP > 4 s or CLS > 0.25', priority: 'Medium' },
  { area: 'Entity clarity', check: 'Brand name consistent across sources', pass: 'Identical across GBP, Wikidata, LinkedIn, schema', fail: 'Variations in capitalisation, abbreviation, or punctuation', priority: 'Critical' },
  { area: 'Entity clarity', check: 'Category descriptor consistent', pass: 'Same category label across all authoritative sources', fail: 'Different industry categories on different platforms', priority: 'Critical' },
  { area: 'Entity clarity', check: 'sameAs links in Organization schema', pass: 'Links to Wikidata, LinkedIn, GBP, Companies House', fail: 'sameAs absent or links to non-authoritative sources', priority: 'High' },
  { area: 'Schema coverage', check: 'Article/TechArticle on content pages', pass: 'Present with headline, author, publisher, date, image', fail: 'Absent on content pages or missing required fields', priority: 'Critical' },
  { area: 'Schema coverage', check: 'FAQPage on FAQ sections', pass: 'Present with Question + acceptedAnswer pairs matching on-page text', fail: 'Absent despite on-page FAQ section', priority: 'High' },
  { area: 'Schema coverage', check: 'BreadcrumbList on non-homepage pages', pass: 'Present, correct hierarchy, valid URLs', fail: 'Absent or broken breadcrumb paths', priority: 'High' },
  { area: 'Content extractability', check: 'Opening sentence is definitional', pass: 'First sentence answers the primary query directly', fail: 'Intro is context-building, rhetorical, or vague', priority: 'High' },
  { area: 'Content extractability', check: 'Paragraphs are 2–4 sentences', pass: 'No paragraph exceeds four sentences', fail: 'Multi-concept paragraphs of 6+ sentences present', priority: 'High' },
  { area: 'Content extractability', check: 'FAQ section present', pass: '4–6 Q&As with standalone answers on every content page', fail: 'No FAQ section on content pages', priority: 'High' },
  { area: 'Citation baseline', check: 'Brand cited in target queries', pass: 'Appears in ≥2 of 5 platforms for core queries', fail: 'Absent from all platforms for category queries', priority: 'High' },
  { area: 'Citation baseline', check: 'Description accuracy when cited', pass: 'Brand description is accurate and current', fail: 'Hallucinated attributes or outdated description', priority: 'Medium' }
