    icon: `<svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
  },
  {
    title: 'Best AI Tools for GEO',
    slug: '/best-ai-tools-geo/',
    tag: 'AI Tooling',
    desc: 'Tools across the full GEO workflow — from audit and entity analysis through to content optimisation and ongoing citation monitoring.',
    icon: `<svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
  },
  {
    title: 'Best LLM Visibility Tools',
    slug: '/best-llm-visibility-tools/',
