  },
  {
    category: 'Citation Behaviour',
    what: 'Rate at which AI engines cite external sources; citation depth per response; source diversity',
    sources: 'Academic RAG research; platform documentation; practitioner studies',
    caveat: 'Highly variable by platform and query type; no single universal figure',
  },
  {
    category: 'Brand Citation Frequency',
    what: 'How often your brand is cited for target queries across specific AI platforms',
    sources: 'First-party GEO monitoring tools; manual audits',
    caveat: 'The only category where primary measurement is practical and reliable',
  },
  {
    category: 'Competitor Citation Share',
    what: 'Relative citation presence of competing brands on shared target queries',
    sources: 'GEO monitoring tools with competitor tracking',
    caveat: 'Share data is only meaningful relative to a defined query set',
  },
  {
    category: 'Citation Accuracy',
    what: 'Whether AI-generated descriptions of your brand are factually correct and on-message',
    sources: 'Manual review and automated sentiment/entity extraction',
    caveat: 'Qualitative dimension; needs structured review against brand guidelines',
  },
  {
    category: 'Topic Coverage',
    what: 'The range of target topics on which your brand earns citations',
    sources: 'GEO monitoring across a broad query set mapped to your topical map',
    caveat: 'Breadth metrics require a pre-defined topic taxonomy to be meaningful',
  },
];

const reliableSources = [
  {
    source: 'Platform-published data',
    examples: 'Google I/O announcements, Microsoft Build reports, OpenAI usage posts',
    strengths: 'First-hand figures, often largest sample sizes',
    limitations: 'Commercial incentive to present growth positively; metric definitions curated',
  },
  {
    source: 'Independent research firms',
    examples: 'Gartner Hype Cycle, Forrester Wave, Nielsen digital measurement',
    strengths: 'Methodologically rigorous; peer-reviewed or auditable methods',
    limitations: 'Often paywalled; may lag fast-moving platform changes by 6–12 months',
  },
  {
    source: 'Academic research',
    examples: 'Papers on RAG citation behaviour, LLM hallucination rates, source selection',
    strengths: 'Methodologically transparent; reproducible findings',
    limitations: 'Focused on specific models or tasks; may not reflect current production systems',
  },
  {
    source: 'Industry analyst reports',
    examples: 'Search market share trackers, SEO industry surveys, AI tool usage panels',
    strengths: 'Practitioner-relevant framing; trend data over time',
    limitations: 'Methodology variation between publishers; self-selection in survey samples',
  },
];

const faqs = [
  {
    q: 'What statistics are most relevant to GEO performance?',
    a: 'The statistics most relevant to GEO performance fall into three groups: AI platform adoption metrics (how many people are using AI search tools as a primary information source), citation behaviour data (how often AI engines cite external sources), and brand-level citation tracking (how frequently your brand appears in AI-generated answers for target queries). The first two are sourced from industry research; the third is measured directly using GEO monitoring tools.',
  },
  {
    q: 'How quickly is AI search adoption growing?',
    a: 'Reported estimates vary widely depending on the study, geography, and definition used. The consistent directional finding is that AI search tool usage has grown rapidly since 2023 and continues to increase. The more useful question for practitioners is not the absolute adoption rate but the rate at which AI-assisted queries are displacing traditional search on specific intent categories.',
  },
  {
    q: 'Where should I find reliable GEO and AI search statistics?',
    a: 'Reliable primary sources include platform-published data from Google, Microsoft, and OpenAI; independent research firms such as Gartner and Forrester; academic papers on RAG and LLM citation behaviour; and industry analyst reports tracking search market share. For brand-level citation statistics, primary measurement using GEO monitoring tools is the only reliable source.',
  },
  {
    q: 'Can I measure my own GEO statistics?',
    a: 'Yes. Brand-level GEO statistics — citation frequency, citation accuracy, share of voice across AI platforms, and topic coverage — are measurable using dedicated GEO monitoring tools. These tools submit target queries to AI engines on a scheduled basis and track whether your brand is cited and how it is described.',
  },
  {
    q: 'What is the relationship between traditional SEO metrics and GEO statistics?',
    a: 'Traditional SEO metrics and GEO statistics are related but distinct. As AI-generated answers intercept an increasing share of informational queries, the click-through value of ranking positions changes. Brands that track both sets of metrics are better positioned to detect when AI search is affecting organic traffic and to attribute changes correctly.',
  },
  {
    q: 'How often should GEO statistics be tracked?',
    a: 'Brand-level GEO citation statistics should be tracked at least weekly for actively optimised query sets, and monthly for broader topic coverage. AI models update frequently and citation patterns can shift after model updates even without changes to your content.',
  },
];

const related = [
  {
    tag: 'NODE',
    title: 'GEO Metrics: How to Measure AI Citation Performance',
    excerpt: 'The full metrics framework for tracking citation frequency, share of voice, and brand accuracy across AI platforms.',
    href: '/geo-metrics/',
  },
  {
    tag: 'Guide',
    title: 'How to Measure GEO',
    excerpt: 'Step-by-step guidance on setting up GEO measurement, choosing monitoring tools, and interpreting citation data.',
    href: '/how-to-measure-geo/',
  },
  {
