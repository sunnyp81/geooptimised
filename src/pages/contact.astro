---
import Base from '../layouts/Base.astro';

const title = 'Submit a source: report incorrect claims';
const description = 'Found an AI search claim we graded wrong? Submit your source. We regrade publicly and log all changes. Help us stay accurate.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://geooptimised.com/' },
    { '@type': 'ListItem', position: 2, name: 'Contact', item: 'https://geooptimised.com/contact/' },
  ],
};
---
<Base title={title} description={description} schema={schema}>
  <section class="wrap pt-14 pb-24 max-w-[46rem]">
    <nav aria-label="Breadcrumb" class="data text-[0.7rem] uppercase tracking-widest mb-6" style="color: var(--muted);">
      <a href="/">Home</a> <span aria-hidden="true">/</span> <span style="color: var(--text);">Contact</span>
    </nav>
    <h1 class="font-display font-bold text-[2.2rem] sm:text-[2.9rem] leading-[1.08] max-w-[18ch] mb-6">
      Send us a source
    </h1>

    <p class="mb-5 text-[1.05rem]" style="color: var(--text-soft);">
      There is nothing to book here and nothing to buy. The one thing genuinely worth your email is a primary source
      we missed, or a grade you think we got wrong.
    </p>

    <div class="border p-6 mb-10" style="border-color: var(--line-strong); background: var(--surface);">
      <p class="data text-[0.62rem] uppercase tracking-[0.14em] mb-3" style="color: var(--muted);">Email</p>
      <p class="font-display text-[1.4rem]">
        <a class="link" href="mailto:hello@geooptimised.com">hello@geooptimised.com</a>
      </p>
    </div>

    <h2 class="font-display text-[1.5rem] font-bold mb-4">What happens next</h2>
    <ol class="space-y-3 mb-10 list-decimal pl-5" style="color: var(--text-soft);">
      <li>We fetch the source you send and try to read the number off it ourselves.</li>
      <li>If it holds up, the claim is regraded and the change is logged on <a class="link" href="/corrections/">corrections</a>, permanently, with the date and what changed.</li>
      <li>If it does not hold up, we will tell you why, and that reasoning goes on the claim.</li>
    </ol>

    <p class="text-[0.95rem]" style="color: var(--muted);">
      We do not offer GEO consultancy, audits or retainers, and we will not refer you to anyone who pays us to.
      Our full commercial position is on <a class="link" href="/who-pays-us/">who pays us</a>.
    </p>
  </section>
</Base>
