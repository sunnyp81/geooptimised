            <tr class="border-b hair bg-white/[.03]">
              <th scope="col" class="px-4 py-3 text-left font-semibold text-white">Tool</th>
              <th scope="col" class="px-4 py-3 text-left font-semibold text-white">Primary Purpose</th>
              <th scope="col" class="px-4 py-3 text-left font-semibold text-white">Cost Indicator</th>
            </tr>
          </thead>
          <tbody class="divide-y hair">
            {toolingRows.map(row => (
              <tr class="transition hover:bg-white/[.02]">
                <td class="px-4 py-3 font-semibold text-white">{row.tool}</td>
                <td class="px-4 py-3 text-ink-300">{row.purpose}</td>
                <td class="px-4 py-3 text-ink-300">{row.cost}</td>
