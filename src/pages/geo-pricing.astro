---
import Base from '../layouts/Base.astro';

const title = 'GEO Pricing: What GEO Services Cost | GEOoptimised';
const description = 'Understand GEO pricing models — retainer, project, and audit — and the factors that drive the cost of generative engine optimisation services. Indicative ranges explained.';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "GEO Pricing: What GEO Services Cost",
    "description": "A guide to generative engine optimisation pricing models, the factors that drive cost, and indicative investment ranges for audits, retainers, and project-based GEO engagements.",
    "url": "https://geooptimised.com/geo-pricing/",
    "image": "https://geooptimised.com/og-image.png",
    "datePublished": "2026-06-07",
    "dateModified": "2026-06-07",
    "inLanguage": "en-GB",
    "author": {
      "@id": "https://geooptimised.com/#organization"
    },
    "publisher": {
      "@id": "https://geooptimised.com/#organization"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does a GEO audit cost?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A GEO audit covers AI visibility assessment across major platforms, competitor citation analysis, entity gap review, and a prioritised action plan. Indicative cost ranges from the low thousands for a focused scope to five figures for a comprehensive multi-platform, multi-competitor audit for a large organisation. The exact cost depends on brand complexity, number of platforms in scope, and the depth of competitor analysis required. Contact GEOoptimised for a scoped estimate."
        }
      },
      {
        "@type": "Question",
        "name": "What does a GEO retainer typically cost per month?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Monthly GEO retainers vary significantly based on scope: the volume of content work, number of brands or platforms covered, monitoring intensity, and reporting requirements. Retainers for focused programmes with a single brand typically start at a few thousand pounds per month. Larger programmes with extensive content production, multi-platform monitoring, and dedicated reporting can run to five figures monthly. These are indicative ranges — actual pricing is scoped to your specific requirements."
        }
      },
      {
        "@type": "Question",
        "name": "Is GEO priced differently from SEO?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "GEO and SEO share similar pricing models — audits, retainers, and project work — but GEO tends to be priced at a premium to equivalent SEO scopes. The specialist nature of the discipline, the manual effort required for AI citation monitoring, and the relative scarcity of genuine GEO expertise all contribute to higher rates compared with commodity SEO services."
        }
      },
      {
        "@type": "Question",
        "name": "When does a retainer make more sense than a project engagement?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A retainer is appropriate when AI visibility is a sustained commercial priority and the competitive landscape means that citation positions will shift over time. Retainers are also necessary when continuous content production, entity maintenance, and platform monitoring are required. A project engagement suits defined-scope work — an audit, a content architecture review, a structured data specification — where the deliverable is a document or recommendation set rather than ongoing execution."
        }
      },
      {
        "@type": "Question",
        "name": "What drives GEO pricing up?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The main cost drivers in GEO pricing are: brand complexity (multiple brands or divisions require separate entity and content strategies); content volume (more pages to optimise means more work); platform scope (covering six AI platforms costs more than covering two); competitive intensity (highly contested queries require more thorough competitive analysis and faster iteration); monitoring depth (daily platform querying across many query clusters costs more than monthly checks); and reporting requirements (custom dashboards and executive reporting carry additional cost)."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://geooptimised.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "GEO Services",
        "item": "https://geooptimised.com/geo-services/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "GEO Pricing",
        "item": "https://geooptimised.com/geo-pricing/"
      }
    ]
  }
];

const costDrivers = [
  {
    driver: 'Brand and domain complexity',
    impact: 'High',
    detail: 'Single focused brand with one domain is simplest. Multi-brand organisations, holding companies, and businesses with separate international domains require separate entity strategies and content programmes per brand — multiplying scope considerably.',
  },
  {
    driver: 'Content volume and condition',
    impact: 'High',
    detail: 'A site with 50 pages that are structurally well-organised needs less optimisation work than a site with 5,000 pages in poor condition. Content auditing and prioritisation at scale is labour-intensive, and production of new citation-target content adds to cost.',
  },
  {
    driver: 'Platform scope',
    impact: 'Medium',
    detail: 'Optimising for and monitoring two platforms costs less than covering six. Most programmes prioritise ChatGPT, Perplexity, Gemini, and Copilot as the core four, with additional platforms added based on audience research.',
  },
  {
    driver: 'Competitive intensity',
    impact: 'Medium',
    detail: 'In categories where multiple well-resourced competitors are also investing in GEO, the work required to earn and maintain citations is higher. Competitive citation analysis and rapid iteration cycles add to the ongoing effort.',
  },
  {
    driver: 'Monitoring depth and frequency',
    impact: 'Medium',
    detail: 'Daily platform querying across a broad query set, with accuracy monitoring and alert systems, costs more than monthly snapshot monitoring. Enterprise brands with reputational risk concerns typically require more intensive monitoring.',
  },
  {
    driver: 'Reporting and governance requirements',
    impact: 'Low–Medium',
    detail: 'Standard monthly reporting is included in most retainers. Custom dashboards, executive-level reporting packs, multi-team stakeholder reporting, and governance documentation add incremental cost.',
  },
];

const faqs = [
  {
    q: 'How much does a GEO audit cost?',
    a: 'A GEO audit covers AI visibility assessment across major platforms, competitor citation analysis, entity gap review, and a prioritised action plan. Indicative cost ranges from the low thousands for a focused scope to five figures for a comprehensive multi-platform, multi-competitor audit for a large organisation. The exact cost depends on brand complexity, number of platforms in scope, and the depth of competitor analysis required. Contact GEOoptimised for a scoped estimate.',
  },
  {
    q: 'What does a GEO retainer typically cost per month?',
    a: 'Monthly GEO retainers vary significantly based on scope: the volume of content work, number of brands or platforms covered, monitoring intensity, and reporting requirements. Retainers for focused programmes with a single brand typically start at a few thousand pounds per month. Larger programmes with extensive content production, multi-platform monitoring, and dedicated reporting can run to five figures monthly. These are indicative ranges — actual pricing is scoped to your specific requirements.',
  },
  {
    q: 'Is GEO priced differently from SEO?',
    a: 'GEO and SEO share similar pricing models — audits, retainers, and project work — but GEO tends to be priced at a premium to equivalent SEO scopes. The specialist nature of the discipline, the manual effort required for AI citation monitoring, and the relative scarcity of genuine GEO expertise all contribute to higher rates compared with commodity SEO services.',
  },
  {
    q: 'When does a retainer make more sense than a project engagement?',
    a: 'A retainer is appropriate when AI visibility is a sustained commercial priority and the competitive landscape means that citation positions will shift over time. Retainers are also necessary when continuous content production, entity maintenance, and platform monitoring are required. A project engagement suits defined-scope work — an audit, a content architecture review, a structured data specification — where the deliverable is a document or recommendation set rather than ongoing execution.',
  },
  {
    q: 'What drives GEO pricing up?',
    a: 'The main cost drivers in GEO pricing are: brand complexity (multiple brands or divisions require separate entity and content strategies); content volume (more pages to optimise means more work); platform scope (covering six AI platforms costs more than covering two); competitive intensity (highly contested queries require more thorough competitive analysis and faster iteration); monitoring depth (daily platform querying across many query clusters costs more than monthly checks); and reporting requirements (custom dashboards and executive reporting carry additional cost).',
  },
];

const related = [
  { tag: 'Services', title: 'GEO Services Overview', excerpt: 'The full range of generative engine optimisation services and what each one involves.', href: '/geo-services/' },
  { tag: 'Consulting', title: 'GEO Consulting Services', excerpt: 'Advisory-led engagements for teams that need strategic direction and expert input.', href: '/geo-consulting/' },
  { tag: 'Enterprise', title: 'Enterprise AI Optimisation', excerpt: 'GEO programmes designed for large organisations: multi-brand, governed, and scaled.', href: '/enterprise-ai-optimisation/' },
];
---

<Base
  title={title}
  description={description}
  schema={schema}
  canonical="https://geooptimised.com/geo-pricing/"
  ogType="website"
>

  <!-- Breadcrumb -->
  <nav aria-label="Breadcrumb" class="container-wide pt-8">
    <ol class="flex items-center gap-1.5 text-sm text-ink-300">
      <li><a href="/" class="transition hover:text-[var(--accent)]">Home</a></li>
      <li aria-hidden="true">/</li>
      <li><a href="/geo-services/" class="transition hover:text-[var(--accent)]">GEO Services</a></li>
      <li aria-hidden="true">/</li>
      <li class="text-ink-200" aria-current="page">GEO Pricing</li>
    </ol>
  </nav>

  <!-- Hero -->
  <header class="hero-fade relative overflow-hidden">
    <div class="container-wide grid gap-12 pt-12 pb-20 lg:grid-cols-12 lg:items-center">
      <div class="lg:col-span-7">
        <span class="eyebrow">Transparency</span>
        <h1 class="mt-4 font-display text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
          <span class="grad-text">GEO Pricing: What GEO Services Cost</span>
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-300">
          GEO pricing is not a fixed menu. Costs are driven by scope, brand complexity, content volume, and the intensity of monitoring required. This page explains the three pricing models used in generative engine optimisation, the factors that push costs up or down, and what indicative investment ranges look like — so you can engage a commercial conversation with realistic expectations.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/contact/" class="btn btn-primary">Get a Quote</a>
          <a href="/geo-services/" class="btn btn-ghost">View All Services</a>
        </div>
      </div>
      <div class="lg:col-span-5">
        <div class="card p-6">
          <span class="eyebrow">On this page</span>
          <ul class="mt-4 space-y-2 text-sm text-ink-300">
            <li><a href="#pricing-models" class="text-accent-400 underline decoration-accent-500/30 underline-offset-2 hover:text-accent-300">The three GEO pricing models</a></li>
            <li><a href="#indicative-ranges" class="text-accent-400 underline decoration-accent-500/30 underline-offset-2 hover:text-accent-300">Indicative investment ranges</a></li>
            <li><a href="#cost-drivers" class="text-accent-400 underline decoration-accent-500/30 underline-offset-2 hover:text-accent-300">What drives GEO cost up or down</a></li>
            <li><a href="#model-comparison" class="text-accent-400 underline decoration-accent-500/30 underline-offset-2 hover:text-accent-300">Choosing the right model</a></li>
            <li><a href="#faq" class="text-accent-400 underline decoration-accent-500/30 underline-offset-2 hover:text-accent-300">Frequently asked questions</a></li>
          </ul>
        </div>
      </div>
    </div>
  </header>

  <!-- Pricing disclaimer -->
  <section class="container-wide py-8">
    <div class="card border border-[var(--accent)]/20 p-5 max-w-3xl">
      <p class="text-sm text-ink-300 leading-relaxed"><strong class="text-ink-100">A note on the figures on this page:</strong> All investment ranges given here are indicative only, based on the scope categories described. Actual pricing depends on your specific situation. GEOoptimised scopes every engagement individually — contact us for a quote based on your requirements.</p>
    </div>
  </section>

  <!-- Pricing Models -->
  <section class="container-wide py-20" id="pricing-models">
    <span class="eyebrow">Pricing models</span>
    <h2 class="mt-3 font-display text-3xl font-bold grad-text sm:text-4xl">The Three GEO Pricing Models</h2>
    <p class="mt-4 max-w-2xl text-ink-300 leading-relaxed">
      <strong>Generative engine optimisation services are priced across three models.</strong> Which model applies depends on what you need: a one-time diagnostic, an ongoing programme, or a defined-scope project with a clear deliverable.
    </p>

    <div class="mt-12 grid gap-6 lg:grid-cols-3">

      <!-- Audit -->
      <div class="card p-8 flex flex-col border-t-2 border-t-[var(--accent)]">
        <span class="eyebrow">Model 1</span>
        <h3 class="mt-2 font-display text-2xl font-bold text-ink-50">One-Off Audit</h3>
        <p class="mt-3 text-sm leading-relaxed text-ink-300 flex-1">A standalone AI visibility audit is the entry point for most GEO engagements. It produces a baseline visibility map, competitor citation analysis, entity gap assessment, and a prioritised action plan — without committing to ongoing delivery.</p>
        <ul class="mt-6 space-y-2 text-sm">
          <li class="flex items-start gap-2 text-ink-200">
            <svg aria-hidden="true" class="mt-0.5 h-4 w-4 shrink-0 text-[var(--accent)]" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span>Fixed scope, fixed price</span>
          </li>
          <li class="flex items-start gap-2 text-ink-200">
            <svg aria-hidden="true" class="mt-0.5 h-4 w-4 shrink-0 text-[var(--accent)]" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span>Typically 2–4 weeks to complete</span>
          </li>
          <li class="flex items-start gap-2 text-ink-200">
            <svg aria-hidden="true" class="mt-0.5 h-4 w-4 shrink-0 text-[var(--accent)]" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span>No ongoing commitment</span>
          </li>
          <li class="flex items-start gap-2 text-ink-200">
            <svg aria-hidden="true" class="mt-0.5 h-4 w-4 shrink-0 text-[var(--accent)]" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span>Often the precursor to a retainer</span>
          </li>
        </ul>
        <div class="mt-8 rounded-lg bg-geo-900 p-4">
          <p class="font-mono text-xs text-ink-300 uppercase tracking-wider">Indicative range</p>
          <p class="mt-1 font-display text-lg font-semibold text-ink-50">Low-to-mid thousands</p>
          <p class="mt-1 text-xs text-ink-500">Varies by brand complexity and competitive scope. Contact for a scoped estimate.</p>
        </div>
      </div>

      <!-- Retainer -->
      <div class="card p-8 flex flex-col border-t-2 border-t-[var(--accent)]">
        <span class="eyebrow">Model 2</span>
        <h3 class="mt-2 font-display text-2xl font-bold text-ink-50">Monthly Retainer</h3>
        <p class="mt-3 text-sm leading-relaxed text-ink-300 flex-1">An ongoing retainer delivers continuous content optimisation, entity maintenance, platform monitoring, and regular reporting. It is the right model when AI visibility is a sustained priority and competitive positions require active management.</p>
        <ul class="mt-6 space-y-2 text-sm">
          <li class="flex items-start gap-2 text-ink-200">
            <svg aria-hidden="true" class="mt-0.5 h-4 w-4 shrink-0 text-[var(--accent)]" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span>Ongoing execution and monitoring</span>
          </li>
          <li class="flex items-start gap-2 text-ink-200">
            <svg aria-hidden="true" class="mt-0.5 h-4 w-4 shrink-0 text-[var(--accent)]" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span>Monthly reporting and review</span>
          </li>
          <li class="flex items-start gap-2 text-ink-200">
            <svg aria-hidden="true" class="mt-0.5 h-4 w-4 shrink-0 text-[var(--accent)]" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span>Typically 6–12 month minimum term</span>
          </li>
          <li class="flex items-start gap-2 text-ink-200">
            <svg aria-hidden="true" class="mt-0.5 h-4 w-4 shrink-0 text-[var(--accent)]" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span>Scope adjustable at quarterly reviews</span>
          </li>
        </ul>
        <div class="mt-8 rounded-lg bg-geo-900 p-4">
          <p class="font-mono text-xs text-ink-300 uppercase tracking-wider">Indicative range</p>
          <p class="mt-1 font-display text-lg font-semibold text-ink-50">Several thousand/month upward</p>
          <p class="mt-1 text-xs text-ink-500">Scope-dependent. Enterprise programmes with multi-brand coverage and intensive monitoring are priced higher. Contact for a scoped estimate.</p>
        </div>
      </div>

      <!-- Project -->
      <div class="card p-8 flex flex-col border-t-2 border-t-[var(--accent)]">
        <span class="eyebrow">Model 3</span>
        <h3 class="mt-2 font-display text-2xl font-bold text-ink-50">Project-Based</h3>
        <p class="mt-3 text-sm leading-relaxed text-ink-300 flex-1">A project engagement delivers a defined scope — a content architecture review, a structured data implementation, a competitive analysis, or a GEO strategy document — for a fixed fee. The deliverable is a document or specification, not ongoing execution.</p>
        <ul class="mt-6 space-y-2 text-sm">
          <li class="flex items-start gap-2 text-ink-200">
            <svg aria-hidden="true" class="mt-0.5 h-4 w-4 shrink-0 text-[var(--accent)]" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span>Defined deliverable and timeline</span>
          </li>
          <li class="flex items-start gap-2 text-ink-200">
            <svg aria-hidden="true" class="mt-0.5 h-4 w-4 shrink-0 text-[var(--accent)]" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span>Fixed price agreed before work starts</span>
          </li>
          <li class="flex items-start gap-2 text-ink-200">
            <svg aria-hidden="true" class="mt-0.5 h-4 w-4 shrink-0 text-[var(--accent)]" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span>Suited to internal teams needing a strategy to execute</span>
          </li>
          <li class="flex items-start gap-2 text-ink-200">
            <svg aria-hidden="true" class="mt-0.5 h-4 w-4 shrink-0 text-[var(--accent)]" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span>Can be structured as a consulting engagement</span>
          </li>
        </ul>
        <div class="mt-8 rounded-lg bg-geo-900 p-4">
          <p class="font-mono text-xs text-ink-300 uppercase tracking-wider">Indicative range</p>
          <p class="mt-1 font-display text-lg font-semibold text-ink-50">Varies by deliverable scope</p>
          <p class="mt-1 text-xs text-ink-500">Scoped individually. A content architecture review differs substantially in effort from a full competitive strategy document. Contact for a scoped estimate.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Indicative ranges table -->
  <section class="container-wide py-20" id="indicative-ranges">
    <span class="eyebrow">Reference figures</span>
    <h2 class="mt-3 font-display text-3xl font-bold grad-text sm:text-4xl">Indicative GEO Investment Ranges</h2>
    <p class="mt-4 max-w-2xl text-ink-300 leading-relaxed mb-4">
      <strong>The table below gives indicative investment ranges by engagement type and organisational size.</strong> All figures are illustrative only. Actual scopes and pricing are agreed individually — these ranges are provided to help you calibrate budget conversations, not to set fixed expectations.
    </p>
    <p class="mb-10 text-sm text-ink-500 max-w-2xl">Note: GEOoptimised was founded in 2026. The ranges below reflect our assessment of the specialist GEO market, not a historical track record of completed engagements.</p>

    <div class="card overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="border-b border-[var(--line)]">
              <th scope="col" class="px-6 py-4 font-mono text-xs uppercase tracking-wider text-[var(--accent)]">Engagement Type</th>
              <th scope="col" class="px-6 py-4 font-mono text-xs uppercase tracking-wider text-[var(--accent)]">Focused / SME</th>
              <th scope="col" class="px-6 py-4 font-mono text-xs uppercase tracking-wider text-[var(--accent)]">Mid-Market</th>
              <th scope="col" class="px-6 py-4 font-mono text-xs uppercase tracking-wider text-[var(--accent)]">Enterprise / Multi-Brand</th>
            </tr>
          </thead>
          <tbody class="text-ink-300 divide-y divide-[var(--line-soft)]">
            <tr>
              <td class="px-6 py-4 font-medium text-ink-100">AI Visibility Audit (one-off)</td>
              <td class="px-6 py-4">Low-to-mid thousands</td>
              <td class="px-6 py-4">Mid-thousands</td>
              <td class="px-6 py-4">Five figures+</td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-medium text-ink-100">Monthly Retainer (ongoing)</td>
              <td class="px-6 py-4">Low thousands/mo</td>
              <td class="px-6 py-4">Mid thousands/mo</td>
              <td class="px-6 py-4">Five figures/mo</td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-medium text-ink-100">GEO Consulting (project)</td>
              <td class="px-6 py-4">Low-to-mid thousands</td>
              <td class="px-6 py-4">Mid-thousands</td>
              <td class="px-6 py-4">Scoped individually</td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-medium text-ink-100">Enterprise AI Optimisation Programme</td>
              <td class="px-6 py-4">N/A</td>
              <td class="px-6 py-4">N/A</td>
              <td class="px-6 py-4">Scoped individually by brand count and content volume</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
    <p class="mt-6 text-sm text-ink-500 max-w-3xl">These ranges are indicative only and should not be read as fixed prices. GEO is a specialist discipline and pricing reflects scope, expertise, and market scarcity — not commodity SEO rates. For an accurate estimate, <a href="/contact/" class="text-accent-400 underline decoration-accent-500/30 underline-offset-2 hover:text-accent-300">contact GEOoptimised</a> with your requirements.</p>
  </section>

  <!-- Cost Drivers -->
  <section class="container-wide py-20" id="cost-drivers">
    <span class="eyebrow">Cost drivers</span>
    <h2 class="mt-3 font-display text-3xl font-bold grad-text sm:text-4xl">What Drives GEO Pricing Up or Down</h2>
    <p class="mt-4 max-w-2xl text-ink-300 leading-relaxed">
      <strong>GEO pricing is not arbitrary — it follows a logic tied to the effort required to earn and maintain AI citations.</strong> Understanding the cost drivers helps you scope your engagement appropriately and evaluate whether a quoted price reflects the complexity of your situation.
    </p>
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {costDrivers.map(d => (
        <div class="card p-7 flex flex-col">
          <div class="flex items-start justify-between gap-3">
            <h3 class="font-display text-base font-semibold text-ink-50">{d.driver}</h3>
            <span class={`shrink-0 rounded-full px-2.5 py-0.5 font-mono text-xs font-medium ${d.impact === 'High' ? 'bg-[var(--accent)]/15 text-[var(--accent)]' : 'bg-geo-800 text-ink-300'}`}>{d.impact}</span>
          </div>
          <p class="mt-3 text-sm leading-relaxed text-ink-300 flex-1">{d.detail}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Model comparison guidance -->
  <section class="container-wide py-20" id="model-comparison">
    <div class="prose-dark max-w-3xl">
      <span class="eyebrow">Decision guide</span>
      <h2 class="mt-3 font-display text-3xl font-bold grad-text sm:text-4xl">Choosing the Right Pricing Model</h2>
      <p class="mt-6"><strong>The right GEO pricing model depends on your situation, not on which option is cheapest.</strong> Starting with an audit before committing to a retainer is almost always the correct sequence, regardless of organisation size. An audit establishes whether the opportunity justifies the ongoing investment, defines the baseline against which progress will be measured, and prioritises the work so that retainer scope can be set with evidence rather than guesswork.</p>

      <h3>Start with an audit if:</h3>
      <ul>
        <li>You have not previously assessed your AI visibility in a systematic way</li>
        <li>You want to evaluate whether a full GEO programme is commercially justified before committing budget</li>
        <li>Your board or leadership team needs evidence of the AI visibility gap before approving ongoing investment</li>
        <li>You are evaluating GEO agencies and want to compare capability through a bounded engagement before choosing a long-term partner</li>
      </ul>

      <h3>Move to a retainer when:</h3>
      <ul>
        <li>An audit has established that AI visibility is a genuine commercial opportunity in your category</li>
        <li>Competitors are earning AI citations in queries relevant to your business and you need to respond</li>
        <li>Content, entity, and schema work is required at a volume that cannot be completed in a single project engagement</li>
        <li>Ongoing monitoring and iteration are needed to maintain citation positions as AI platforms evolve</li>
      </ul>

      <h3>Choose project-based pricing when:</h3>
      <ul>
        <li>You need a specific deliverable — a strategy document, a content architecture review, a schema specification — and you have an internal team to execute against it</li>
        <li>Your existing <a href="/geo-consulting/" class="text-accent-400 underline decoration-accent-500/30 underline-offset-2 hover:text-accent-300">GEO consulting</a> arrangement suits an advisory model rather than full implementation</li>
        <li>You are addressing a targeted problem — such as inaccurate AI descriptions of your brand — rather than building a comprehensive programme</li>
      </ul>

      <p>For large organisations with multi-brand requirements, governance complexity, or enterprise scale, standard pricing models apply within an <a href="/enterprise-ai-optimisation/" class="text-accent-400 underline decoration-accent-500/30 underline-offset-2 hover:text-accent-300">enterprise AI optimisation programme</a> structure that wraps the individual service components into a coherent programme with appropriate governance and reporting.</p>
    </div>
  </section>

  <!-- GEO vs SEO pricing context -->
  <section class="container-wide py-20">
    <div class="prose-dark max-w-3xl">
      <span class="eyebrow">Context</span>
      <h2 class="mt-3 font-display text-3xl font-bold grad-text sm:text-4xl">How GEO Pricing Compares to SEO</h2>
      <p class="mt-6"><strong>GEO pricing sits at a premium to equivalent SEO scopes, and understanding why matters when evaluating suppliers.</strong> Traditional SEO services are a mature market with significant competitive pressure on pricing. GEO is a newer discipline where genuine specialist expertise is genuinely scarce, which means credible GEO pricing reflects that scarcity — not inflated day rates.</p>
      <p>There are also structural reasons why GEO costs more per unit of output. AI citation monitoring requires manual platform querying at scale — there is no equivalent of a rank-tracking tool that automates the process. Entity work on Wikipedia, Wikidata, and sector databases is time-intensive and requires specialist knowledge. And content optimisation for LLM citation requires a level of editorial judgement that commodity content production does not.</p>
      <p>Be cautious of GEO pricing that matches low-end SEO retainer rates. At those price points, the scope will be insufficient to produce meaningful AI visibility change, or the work will be basic SEO presented under a GEO label. For a breakdown of what genuine GEO work involves, see <a href="/geo-services/" class="text-accent-400 underline decoration-accent-500/30 underline-offset-2 hover:text-accent-300">GEO services</a> and the <a href="/geo-agency/" class="text-accent-400 underline decoration-accent-500/30 underline-offset-2 hover:text-accent-300">GEO agency</a> overview.</p>
    </div>
  </section>

