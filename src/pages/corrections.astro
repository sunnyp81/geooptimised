---
import Base from '../layouts/Base.astro';
import correctionsData from '../data/corrections.json';

const corrections = correctionsData.corrections;

const title = 'Corrections: every error, kept permanently';
const description = 'A permanent, dated log of everything GEOoptimised has got wrong. Nothing is silently edited. The first two entries were our own, made before launch.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://geooptimised.com/' },
    { '@type': 'ListItem', position: 2, name: 'Corrections', item: 'https://geooptimised.com/corrections/' },
  ],
};
---
<Base title={title} description={description} schema={schema}>
  <section class="wrap pt-14 pb-8">
    <nav aria-label="Breadcrumb" class="data text-[0.7rem] uppercase tracking-widest mb-6" style="color: var(--muted);">
      <a href="/">Home</a> <span aria-hidden="true">/</span> <span style="color: var(--text);">Corrections</span>
    </nav>
    <h1 class="font-display font-bold text-[2.2rem] sm:text-[2.9rem] leading-[1.08] max-w-[18ch]">Corrections</h1>
    <p class="mt-6 max-w-[64ch] text-[1.08rem]" style="color: var(--text-soft);">
      Everything we have got wrong, kept here permanently with the date we found out. We do not silently edit
      pages. A site that grades other people's evidence has no business hiding its own mistakes, and the
      cheapest way to prove that is to publish them before anyone catches them.
    </p>
    <p class="mt-4 data text-[0.75rem]" style="color: var(--muted);">
      {corrections.length} {corrections.length === 1 ? 'correction' : 'corrections'} logged
    </p>
  </section>

  <section class="wrap pb-24">
    <ol class="space-y-8 max-w-[52rem]">
      {corrections.map((c, i) => (
        <li id={c.id} class="border scroll-mt-24 fade-up" style="border-color: var(--line); background: var(--surface);">
          <header class="flex flex-wrap items-center gap-x-4 gap-y-2 px-5 py-3 border-b" style="border-color: var(--line); background: var(--bg-2);">
            <span class="data text-[0.72rem] font-semibold" style="color: var(--text);">
              {String(i + 1).padStart(3, '0')}
            </span>
            <span class="data text-[0.72rem]" style="color: var(--muted);">{c.date}</span>
            <span class="data text-[0.6rem] uppercase tracking-[0.12em] px-1.5 py-0.5 border" style="color: var(--muted); border-color: var(--line-strong);">
              {c.status}
            </span>
            <a href={c.affects} class="data text-[0.72rem] ml-auto link">{c.affects}</a>
          </header>

          <div class="px-5 py-5 space-y-5">
            <div>
              <p class="data text-[0.62rem] uppercase tracking-[0.14em] mb-1.5" style="color: var(--g-untraceable);">What we said</p>
              <p class="text-[0.95rem]" style="color: var(--text-soft);">{c.weSaid}</p>
            </div>
            <div class="rule pt-5">
              <p class="data text-[0.62rem] uppercase tracking-[0.14em] mb-1.5" style="color: var(--g-verified);">What is actually true</p>
              <p class="text-[0.95rem]" style="color: var(--text-soft);">{c.actuallyTrue}</p>
            </div>
            <div class="rule pt-5">
              <p class="data text-[0.62rem] uppercase tracking-[0.14em] mb-1.5" style="color: var(--muted);">How we found out</p>
              <p class="text-[0.95rem]" style="color: var(--text-soft);">{c.howWeFoundOut}</p>
            </div>
            <div class="rule pt-5">
              <p class="data text-[0.62rem] uppercase tracking-[0.14em] mb-1.5" style="color: var(--muted);">The lesson</p>
              <p class="font-display text-[1.1rem]" style="color: var(--text);">{c.lesson}</p>
            </div>
          </div>
        </li>
      ))}
    </ol>

    <div class="rule mt-16 pt-10 max-w-[62ch]">
      <h2 class="font-display text-[1.5rem] font-bold mb-4">Why the first entries are our own</h2>
      <p class="mb-4" style="color: var(--text-soft);">
        Both corrections above were made before this site had a single reader. That is not a coincidence, and it
        is not humility theatre. The failure this site exists to catch, a real number quietly drifting as it is
        retold, is not something other people do because they are careless. It happened to us on the claim we
        were most confident about, within hours of starting.
      </p>
      <p style="color: var(--text-soft);">
        If we had not gone back to the primary source, we would have published it. That is the entire argument
        for going back to the primary source.
      </p>
    </div>
  </section>
</Base>
