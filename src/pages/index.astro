---
import Base from '../layouts/Base.astro';

const title = 'GEOoptimised — Get Your Brand Cited by AI Search Engines';
const description = 'GEOoptimised is a Generative Engine Optimisation (GEO) agency that helps brands get cited by ChatGPT, Perplexity, Google AI Overviews, Gemini and Claude.';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "GEOoptimised",
    "url": "https://geooptimised.com",
    "email": "hello@geooptimised.com",
    "description": "Generative Engine Optimisation agency helping brands get cited by AI search engines.",
    "foundingDate": "2026",
    "sameAs": []
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "GEOoptimised",
    "url": "https://geooptimised.com",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://geooptimised.com/?s={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
];

const services = [
  {
    title: 'GEO Guide',
    href: '/generative-engine-optimisation/',
    description: 'The definitive guide to Generative Engine Optimisation. How LLMs select sources, what citation signals matter, and how to earn mentions consistently.'
  },
  {
    title: 'GEO Services',
    href: '/geo-services/',
    description: 'Platform-specific optimisation packages for ChatGPT, Perplexity, Gemini and Google AI Overviews. Audits, citation strategies and ongoing monitoring.'
  },
  {
    title: 'AEO Guide',
    href: '/answer-engine-optimisation/',
    description: 'Answer Engine Optimisation explained. How AEO relates to GEO, featured snippets, voice search and the shift from links to direct answers.'
  },
  {
    title: 'GEO Agency',
    href: '/geo-agency/',
    description: 'Why work with a specialist GEO agency. Our methodology, case studies and how we measure success in AI-generated search results.'
  }
];

const differentiators = [
  {
    title: 'Brand Is the Category',
    text: 'GEOoptimised exists at the intersection of the brand name and the discipline. When someone searches for generative engine optimisation, our content is already semantically aligned with the query.'
  },
  {
    title: 'Practitioner Authority',
    text: 'We do not just write about GEO. We run GEO campaigns, measure citation rates across platforms and publish the results. Every recommendation is backed by live data, not theory.'
  },
  {
    title: 'Dual-Ranking Strategy',
    text: 'Optimising for AI citations does not mean abandoning traditional search. Our methodology improves visibility in both organic results and generative responses simultaneously.'
  },
  {
    title: 'Platform-Specific Playbooks',
    text: 'ChatGPT, Perplexity, Gemini and Google AI Overviews each retrieve and cite sources differently. We maintain tested playbooks for each platform rather than applying a single generic approach.'
  }
];
---

<Base title={title} description={description} schema={schema} ogType="website">

  <!-- Hero -->
  <section class="relative overflow-hidden py-24 sm:py-32">
    <div class="absolute inset-0 bg-gradient-to-b from-accent-500/5 via-transparent to-transparent"></div>
    <div class="relative mx-auto max-w-6xl px-4 text-center">
      <h1 class="mx-auto max-w-3xl text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        Get Your Brand Cited by <span class="text-accent-500">AI</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-300 sm:text-xl">
        Generative Engine Optimisation (GEO) is the practice of making your brand the source that AI search engines cite. ChatGPT, Perplexity, Google AI Overviews, Gemini and Claude are answering the questions your customers ask. GEOoptimised makes sure your brand is part of those answers.
      </p>
      <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/geo-services/" class="inline-flex items-center rounded-lg bg-accent-500 px-6 py-3 text-sm font-semibold text-geo-950 shadow-lg shadow-accent-500/20 transition hover:bg-accent-400 hover:shadow-accent-400/30">
          See Our Services
        </a>
        <a href="/generative-engine-optimisation/" class="inline-flex items-center rounded-lg border border-geo-600 px-6 py-3 text-sm font-semibold text-gray-200 transition hover:border-accent-500 hover:text-white">
          Read the GEO Guide
        </a>
      </div>
    </div>
  </section>

  <!-- What Is GEO? -->
  <section class="py-20">
    <div class="mx-auto max-w-4xl px-4">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">What Is Generative Engine Optimisation?</h2>
      <div class="mt-8 space-y-5 text-gray-300 leading-relaxed">
        <p>
          <strong class="text-white">Generative Engine Optimisation is the discipline of earning citations from large language models.</strong> When a user asks ChatGPT, Perplexity or Google AI Overviews a question, these systems retrieve sources, synthesise an answer and attribute it. GEO determines whether your content is selected as one of those sources.
        </p>
        <p>
          Traditional SEO optimises for a ranked list of ten blue links. GEO optimises for a fundamentally different interface: a single synthesised response that may cite three, five or zero sources. The ranking factors differ too. LLMs favour content that demonstrates topical depth, clear entity relationships, structured data and factual specificity. Domain authority still matters, but it is no longer sufficient on its own. A page can rank first in Google and still be absent from every AI-generated answer.
        </p>
        <p>
          This shift is already measurable. Queries with AI overviews see reduced click-through rates on organic results, which means the brands that are cited inside the AI response capture a disproportionate share of attention and trust. GEOoptimised helps you become one of those cited brands. Our <a href="/generative-engine-optimisation/" class="text-accent-400 underline decoration-accent-500/30 underline-offset-2 transition hover:decoration-accent-400">complete GEO guide</a> covers the methodology in detail.
        </p>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="py-20 border-t border-geo-800/40">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="text-center text-3xl font-bold text-white sm:text-4xl">How We Help</h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-gray-400">
        From strategy guides to hands-on campaign management, everything we do is built around one outcome: getting your brand cited by AI.
      </p>
      <div class="mt-14 grid gap-6 sm:grid-cols-2">
        {services.map(service => (
          <a href={service.href} class="group rounded-xl border border-geo-800/60 bg-geo-900/40 p-6 transition hover:border-accent-500/40 hover:bg-geo-900/70">
            <h3 class="text-lg font-semibold text-white group-hover:text-accent-400 transition">{service.title}</h3>
            <p class="mt-3 text-sm text-gray-400 leading-relaxed">{service.description}</p>
            <span class="mt-4 inline-block text-xs font-medium text-accent-500 group-hover:text-accent-400 transition">Learn more &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why GEOoptimised? -->
  <section class="py-20 border-t border-geo-800/40">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="text-center text-3xl font-bold text-white sm:text-4xl">Why GEOoptimised?</h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-gray-400">
        Most agencies bolt GEO onto an existing SEO retainer as an afterthought. We built the entire practice around it.
      </p>
      <div class="mt-14 grid gap-8 sm:grid-cols-2">
        {differentiators.map(item => (
          <div class="rounded-xl border border-geo-800/40 bg-geo-900/30 p-6">
            <h3 class="text-base font-semibold text-accent-400">{item.title}</h3>
            <p class="mt-3 text-sm text-gray-400 leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 border-t border-geo-800/40">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Ready to Be Visible in AI Search?</h2>
      <p class="mx-auto mt-5 max-w-xl text-gray-300">
        AI search engines are already answering your customers' questions. The only question is whether they are citing your brand or your competitors. Let us run an audit and show you exactly where you stand.
      </p>
      <a href="/contact/" class="mt-8 inline-flex items-center rounded-lg bg-accent-500 px-8 py-3.5 text-sm font-semibold text-geo-950 shadow-lg shadow-accent-500/20 transition hover:bg-accent-400 hover:shadow-accent-400/30">
        Get in Touch
      </a>
    </div>
  </section>

</Base>
