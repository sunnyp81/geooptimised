          <tbody class="divide-y hair">
            <tr class="transition hover:bg-white/[.02]">
              <td class="px-4 py-3 font-semibold text-white">Content opening</td>
              <td class="px-4 py-3 text-ink-300">Context-building intro, hooks the reader</td>
              <td class="px-4 py-3 text-ink-300">Definitional statement answers the query in sentence one</td>
