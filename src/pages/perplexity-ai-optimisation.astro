  inLanguage: 'en-GB',
  datePublished: '2026-06-07',
  dateModified: '2026-06-07',
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': 'https://geooptimised.com/perplexity-ai-optimisation/',
  },
  author: { '@id': 'https://geooptimised.com/#organization' },
  publisher: { '@id': 'https://geooptimised.com/#organization' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What retrieval mechanism does Perplexity AI use?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Perplexity uses retrieval-augmented generation (RAG) for all queries. When a user submits a prompt, Perplexity first retrieves a set of candidate web pages using its own index (built by PerplexityBot), then passes that retrieved content to a large language model as context to generate the final answer. Every cited source in a Perplexity response is a page that was retrieved and used as grounding context — not a result of a fixed training snapshot.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is Perplexity Pro Search and how does it differ from standard search?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Perplexity Pro Search is an enhanced retrieval mode available to Pro subscribers that performs multi-step reasoning: it decomposes complex queries into sub-queries, retrieves sources for each sub-query separately, and synthesises across multiple retrieval rounds. Standard Perplexity search performs a single retrieval pass. Pro Search surfaces a broader set of sources for complex questions and is more likely to consult specialist publications, academic sources, and in-depth content. Optimising for Pro Search requires the same foundations as standard search but with greater emphasis on depth and specificity.",
      },
    },
    {
      '@type': 'Question',
      name: 'How does Perplexity decide which sources to cite?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Perplexity's source selection involves two stages. In the retrieval stage, it selects candidate pages based on query relevance, domain authority signals, and recency. In the synthesis stage, the language model reads the retrieved content and selects passages to cite based on their direct relevance to the query, extractability of the key claim, and uniqueness of the information. Pages with clear declarative statements, specific data, and low ambiguity are more likely to survive from retrieval through to final citation.",
      },
    },
    {
      '@type': 'Question',
      name: 'Do Perplexity focus modes change which sources are cited?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Yes. Perplexity's focus modes — Web, Academic, Writing, Video, Social, and Wolfram Alpha — constrain the retrieval index and source types used. Academic focus prioritises peer-reviewed publications and scholarly sources. Social focus sources from platforms like Reddit and Twitter/X. Web (the default) draws from Perplexity's general web index. Brands seeking citations in general-purpose answers should optimise for the Web focus, which represents the majority of queries. Brands in research-adjacent categories may also benefit from academic publishing or citation in well-sourced articles that Academic mode retrieves.",
      },
    },
    {
      '@type': 'Question',
      name: 'Does Perplexity use the same index as Google or Bing?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "No. Perplexity maintains its own web index, built by its proprietary crawler PerplexityBot. This is distinct from Google's index and Bing's index. A page that ranks number one in Google is not automatically included in Perplexity's retrieval results — it must be independently crawled by PerplexityBot. Conversely, a page with relatively modest Google rankings can still achieve strong Perplexity citation if it is well-structured, recently updated, and accessible to PerplexityBot.",
      },
    },
    {
      '@type': 'Question',
      name: 'How often does Perplexity update its index?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Perplexity's index is updated continuously, with PerplexityBot crawling the web on an ongoing basis. The crawl frequency for a given domain appears to correlate with publishing cadence and domain authority — higher-activity, more authoritative sites are recrawled more frequently. For time-sensitive content, Perplexity also surfaces results from its real-time web access capability, which retrieves live pages at query time for queries where recency is particularly important.",
      },
    },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://geooptimised.com/' },
