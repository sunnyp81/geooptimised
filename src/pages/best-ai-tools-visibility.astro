                <td class="px-5 py-4 text-ink-300">AI share of voice relative to competitors</td>
                <td class="px-5 py-4 text-ink-300">Competitive strategy; board-level reporting</td>
              </tr>
              <tr class="hover:bg-[var(--bg-2)] transition-colors">
                <td class="px-5 py-4 font-medium text-ink-100">Multi-platform dashboards</td>
                <td class="px-5 py-4 text-ink-300">Unified cross-platform visibility view</td>
                <td class="px-5 py-4 text-ink-300">Visibility by platform and topic cluster</td>
