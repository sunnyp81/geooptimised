                <th scope="col" class="px-5 py-4 text-left font-semibold text-ink-100">Indicative budget</th>
                <th scope="col" class="px-5 py-4 text-left font-semibold text-ink-100">Priority criteria</th>
                <th scope="col" class="px-5 py-4 text-left font-semibold text-ink-100">What to avoid</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-[var(--line)]">
              {buyerProfiles.map((row, i) => (
