const growthDrivers = [
  {
    driver: 'AI search adoption',
    description: 'The share of informational queries handled by AI-generated answer platforms is growing across all major markets. Each percentage point shift in query volume from traditional search to AI search increases the importance of AI citation presence relative to keyword rankings.',
    trajectory: 'Upward — consistent across credible source categories; rate disputed but direction is not',
  },
  {
    driver: 'Enterprise AI integration',
    description: 'AI assistants are being embedded in enterprise software, customer service tools, and internal knowledge systems. These enterprise AI deployments retrieve and synthesise web content, extending the GEO surface area beyond consumer search engines.',
