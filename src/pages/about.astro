---
import Base from '../layouts/Base.astro';

const title = 'About GEOoptimised | Generative Engine Optimisation Agency';
const description = 'GEOoptimised is a Generative Engine Optimisation agency focused exclusively on AI search visibility — helping brands get cited by ChatGPT, Perplexity, Gemini and AI Overviews.';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "About GEOoptimised",
    "url": "https://geooptimised.com/about/",
    "description": "GEOoptimised is a specialist Generative Engine Optimisation agency focused exclusively on AI search visibility, founded in 2026.",
    "mainEntity": {
      "@type": "Organization",
      "name": "GEOoptimised",
      "url": "https://geooptimised.com",
      "email": "hello@geooptimised.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://geooptimised.com/icon-512.png"
      },
      "description": "Generative Engine Optimisation agency helping brands earn citations from AI search engines including ChatGPT, Perplexity, Gemini and Google AI Overviews.",
      "foundingDate": "2026",
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "hello@geooptimised.com",
        "contactType": "customer enquiries"
      },
      "knowsAbout": [
        "Generative Engine Optimisation",
        "Answer Engine Optimisation",
        "AI search visibility",
        "Entity authority",
        "Structured data and schema markup",
        "LLM retrieval mechanics",
        "llms.txt optimisation",
        "Cross-platform AI citation strategy",
        "Knowledge graph optimisation",
        "Topical authority architecture"
      ]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://geooptimised.com/" },
      { "@type": "ListItem", "position": 2, "name": "About", "item": "https://geooptimised.com/about/" }
    ]
  }
];

const expertise = [
  {
    title: 'Generative Engine Optimisation',
    text: 'Full-spectrum GEO strategy covering citation acquisition, source positioning and retrieval-augmented generation alignment across all major AI platforms.',
  },
  {
    title: 'Answer Engine Optimisation',
    text: 'AEO methodology for featured snippets, voice search and direct-answer formats that feed into both traditional and AI-generated results.',
  },
  {
    title: 'Entity Authority Architecture',
    text: 'Building the entity signals, knowledge graph presence and topical authority structures that LLMs use to identify and rank trusted sources.',
  },
  {
    title: 'Structured Data Strategy',
    text: 'Schema markup implementation that gives language models clean, machine-readable signals about your content, brand relationships and expertise.',
  },
  {
    title: 'LLM Retrieval Mechanics',
    text: 'Deep understanding of how large language models tokenise queries, score relevance and select sources for citation in generated responses.',
  },
  {
    title: 'Cross-Platform Visibility',
    text: 'Platform-specific playbooks for ChatGPT, Perplexity, Gemini and Google AI Overviews, each calibrated to how that engine retrieves and cites.',
  },
];
---

<Base title={title} description={description} schema={schema} canonical="https://geooptimised.com/about/">

  <!-- Breadcrumb -->
  <nav aria-label="Breadcrumb" class="container-wide pt-8">
    <ol class="flex items-center gap-2 font-mono text-xs text-ink-400">
      <li><a href="/" class="transition hover:text-[var(--accent)]">Home</a></li>
      <li aria-hidden="true" class="select-none">/</li>
      <li class="text-ink-300">About</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="hero-fade relative overflow-hidden pt-12 pb-20 sm:pt-16 sm:pb-28">
    <div class="container-wide text-center">
      <p class="eyebrow">About GEOoptimised</p>
      <h1 class="grad-text mx-auto mt-5 max-w-4xl font-display text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
        Built for the AI Search Era
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-ink-300">
        A Generative Engine Optimisation agency built from the ground up for the AI search era. We help brands earn the citations that matter when answers replace links.
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 sm:py-20">
    <div class="container-wide max-w-3xl prose-dark">

      <h2>Why We Exist</h2>
      <p>
        The search landscape has fundamentally shifted. ChatGPT, Perplexity, Google AI Overviews, Gemini and Claude now answer the questions your customers ask — often without a single click to a website. Brands that rely solely on traditional blue-link rankings are losing visibility to competitors who understand how large language models retrieve, evaluate and cite sources. GEOoptimised was founded on a simple principle: if AI is the new search interface, then earning AI citations is the new SEO. Our discipline is <a href="/generative-engine-optimisation/" class="text-accent-400 underline decoration-accent-500/30 underline-offset-2 hover:text-accent-300">generative engine optimisation</a> — and it is the only thing we do.
      </p>

      <h2>What We Do</h2>
      <p>
        GEOoptimised is a <strong>Generative Engine Optimisation</strong> agency focused exclusively on AI search visibility. We do not bolt GEO onto an existing SEO retainer as an afterthought. Every engagement, every methodology and every measurement framework we use is designed around one outcome: making your brand the source that AI search engines cite.
      </p>
      <p>
        Our work spans the full spectrum of AI discoverability. We optimise for <strong>entity authority</strong> so that LLMs recognise your brand as a trusted source within your niche. We implement <strong>structured data and schema markup</strong> that gives language models clean, machine-readable signals about your content. We configure <strong>llms.txt</strong> files and AI crawler directives so your most important content is accessible to retrieval systems. And we build <strong>cross-platform citation strategies</strong> that account for the differences in how ChatGPT, Perplexity, Gemini and Google AI Overviews each select their sources.
      </p>

      <h2>How We Think</h2>
      <p>
        GEOoptimised combines deep technical SEO expertise with a practical understanding of LLM retrieval mechanics. We study how language models tokenise queries, score relevance, and decide which sources to surface in a response. This is not guesswork — we test, measure citation rates across platforms, and refine our approach based on live data.
      </p>
      <p>
        We also believe in practising what we preach. This site is itself optimised for AI citation. From the semantic structure of every page to the entity relationships in our schema, everything is built to demonstrate the methodology we recommend to clients. If you ask an AI about Generative Engine Optimisation agencies, we intend to be cited. You can see the full scope of what we deliver on our <a href="/geo-services/" class="text-accent-400 underline decoration-accent-500/30 underline-offset-2 hover:text-accent-300">GEO services</a> page.
      </p>

    </div>
  </section>

  <!-- Expertise Grid -->
  <section class="border-t border-[var(--line)] py-16 sm:py-20">
    <div class="container-wide">
      <p class="eyebrow">Core Competencies</p>
      <h2 class="mt-4 font-display text-3xl font-bold text-white tracking-tight sm:text-4xl">Our Expertise</h2>
      <p class="mt-4 max-w-2xl text-ink-300">
        Our core competencies span every dimension of AI search visibility — from the technical mechanics of LLM retrieval to the strategic positioning that earns citations at scale.
      </p>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {expertise.map((item) => (
          <div class="card card-hover p-6">
            <h3 class="font-display text-lg font-semibold text-white">{item.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-ink-300">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-[var(--line)] py-20 sm:py-24">
    <div class="container-wide max-w-3xl text-center">
      <h2 class="font-display text-3xl font-bold text-white tracking-tight sm:text-4xl">Ready to Be Cited by AI?</h2>
      <p class="mx-auto mt-5 max-w-xl text-ink-300">
        Every day your competitors are being cited in AI-generated answers while your brand is absent. Let us show you exactly where you stand and how to change it.
      </p>
      <a href="/contact/" class="btn btn-primary mt-8">Get in Touch</a>
    </div>
  </section>

</Base>
