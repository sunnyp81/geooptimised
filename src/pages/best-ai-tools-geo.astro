                <p class="text-sm font-semibold text-ink-100">Audit</p>
                <p class="text-xs text-ink-300">Baseline measurement and gap analysis</p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-[var(--bg-2)] border border-[var(--line)] font-mono text-sm font-semibold text-[var(--accent)]">2</div>
              <div>
                <p class="text-sm font-semibold text-ink-100">Optimise</p>
                <p class="text-xs text-ink-300">Content, structure, schema and entity work</p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-[var(--bg-2)] border border-[var(--line)] font-mono text-sm font-semibold text-[var(--accent)]">3</div>
