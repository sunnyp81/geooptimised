---
import Base from '../layouts/Base.astro';

const title = 'GEO Agency: Generative Engine Optimisation Experts';
const description = 'GEOoptimised is a specialist generative engine optimisation agency. We help brands appear in AI-generated answers across ChatGPT, Perplexity, Gemini and Copilot.';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'ProfessionalService',
    name: 'GEOoptimised',
    url: 'https://geooptimised.com/geo-agency/',
    serviceType: 'Generative Engine Optimisation',
    email: 'hello@geooptimised.com',
    description: 'Specialist generative engine optimisation agency helping brands gain visibility in AI-generated search results.',
    areaServed: {
      '@type': 'Country',
      name: 'United Kingdom',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://geooptimised.com/' },
      { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://geooptimised.com/geo-services/' },
      { '@type': 'ListItem', position: 3, name: 'GEO Agency', item: 'https://geooptimised.com/geo-agency/' },
    ],
  },
];

const capabilities = [
  {
    title: 'AI Citation Auditing',
    text: 'We map exactly where your brand appears — and where it does not — across every major generative engine. This baseline audit reveals the gap between your current AI visibility and what your competitors already hold.',
  },
  {
    title: 'Entity Authority Building',
    text: 'Generative engines rely on entity graphs to decide which brands to cite. We strengthen your entity signals through structured data, authoritative mentions, and consistent knowledge-graph presence so AI models treat your brand as a primary source.',
  },
  {
    title: 'Content Architecture for LLMs',
    text: 'Large language models parse content differently from traditional crawlers. We restructure your pages with clear definitional statements, concise Q&A patterns, and semantic markup that LLMs can extract and cite directly.',
  },
  {
    title: 'Source Credibility Optimisation',
    text: 'AI models weight sources by perceived authority. We build the citation footprint that signals credibility: editorial mentions, industry publications, and high-trust third-party references that feed into training and retrieval-augmented generation pipelines.',
  },
  {
    title: 'Cross-Platform Monitoring',
    text: 'Visibility in one AI engine does not guarantee visibility in another. We track your brand mentions across ChatGPT, Perplexity, Gemini, Copilot, and AI Overviews, then adjust strategy based on platform-specific behaviour.',
  },
  {
    title: 'Competitive Intelligence',
    text: 'We analyse which competitors are being cited for your target queries, reverse-engineer the content and entity patterns driving those citations, and build a strategy to displace them systematically.',
  },
];

const steps = [
  { label: 'Audit', desc: 'Map current AI visibility, citation frequency, and entity coverage across all major generative platforms.' },
  { label: 'Strategy', desc: 'Build a prioritised action plan targeting the queries and platforms with the highest commercial value.' },
  { label: 'Implement', desc: 'Execute content restructuring, entity reinforcement, structured data deployment, and source-building campaigns.' },
  { label: 'Monitor', desc: 'Track citation frequency, brand mention accuracy, and competitive positioning in real time.' },
  { label: 'Iterate', desc: 'Refine strategy based on measured results. Generative engines evolve rapidly — your GEO programme must evolve faster.' },
];

const tocItems = [
  { id: 'what-geo-agency-does', label: 'What a GEO Agency Does' },
  { id: 'why-specialist', label: 'Why Choose a Specialist' },
  { id: 'our-approach', label: 'Our Approach' },
  { id: 'results', label: 'Results We Focus On' },
  { id: 'good-fit', label: 'Good Fit / Not a Fit' },
  { id: 'faq', label: 'FAQ' },
  { id: 'related', label: 'Related Reading' },
];

const goodFit = [
  'Your category is being reshaped by AI search',
  'You have domain authority but zero AI citations',
  'Competitors appear in ChatGPT / Perplexity and you do not',
  'You need measurable citation KPIs, not vague "AI readiness"',
  'You want a specialist, not a generalist bolting GEO onto SEO',
];

const notFit = [
  'You need traditional SEO link building only',
  'Your market has no AI search adoption yet',
  'You want a single blog post, not a programme',
  'Budget is under three months of engagement',
  'You expect overnight results from a new discipline',
];

const faqs = [
  {
    q: 'How is GEO different from SEO?',
    a: 'SEO targets search engine results pages. GEO targets the AI-generated answers that are replacing those results. The ranking signals, content structures, and measurement frameworks are fundamentally different.',
  },
  {
    q: 'How long before we see results?',
    a: 'Most clients see measurable changes in citation frequency within 60-90 days. Entity authority and cross-platform visibility compound over 6-12 months.',
  },
  {
    q: 'Which AI platforms do you cover?',
    a: 'ChatGPT, Perplexity, Gemini, Microsoft Copilot, and Google AI Overviews. We monitor all five and adjust strategy per platform.',
  },
  {
    q: 'Do we still need traditional SEO?',
    a: 'Yes. GEO builds on strong organic fundamentals. If your site has poor technical health or thin content, we address that first. GEO and SEO are complementary, not competing.',
  },
  {
    q: 'What does a GEO audit include?',
    a: 'A full citation map across all major generative engines, entity graph analysis, competitor citation benchmarking, and a prioritised action plan with estimated impact.',
  },
];

const related = [
  {
    tag: 'Guide',
    title: 'Generative Engine Optimisation: The Complete Guide',
    excerpt: 'Everything you need to know about GEO — from first principles to advanced entity strategies.',
    href: '/generative-engine-optimisation/',
  },
  {
    tag: 'Service',
    title: 'AEO Agency: Answer Engine Optimisation',
    excerpt: 'How AEO fits within a broader GEO programme and when you need both.',
    href: '/aeo-agency/',
  },
  {
    tag: 'Services',
    title: 'GEO Services Overview',
    excerpt: 'The full range of generative engine optimisation services we deliver.',
    href: '/geo-services/',
  },
];
---

<Base title={title} description={description} schema={schema} ogType="website">

  <!-- Breadcrumb -->
  <nav aria-label="Breadcrumb" class="container-wide pt-8">
    <ol class="flex items-center gap-1.5 text-sm text-ink-400">
      <li><a href="/" class="transition hover:text-[var(--accent)]">Home</a></li>
      <li aria-hidden="true">/</li>
      <li><a href="/geo-services/" class="transition hover:text-[var(--accent)]">Services</a></li>
      <li aria-hidden="true">/</li>
      <li class="text-ink-200" aria-current="page">GEO Agency</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="hero-fade">
    <div class="container-wide pt-16 pb-14">
      <div class="flex flex-wrap items-center gap-3">
        <span class="eyebrow">Service</span>
        <span class="font-mono text-xs text-ink-400">25 May 2025</span>
        <span class="font-mono text-xs text-ink-400">8 min read</span>
      </div>
      <h1 class="mt-5 max-w-3xl font-display text-4xl font-bold leading-tight grad-text md:text-5xl lg:text-6xl">
        GEO Agency: Generative Engine Optimisation Experts
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-200">
        Traditional SEO targets search engine results pages. A <strong class="text-white">generative engine optimisation agency</strong> targets
        something fundamentally different: the AI-generated answers that are replacing those results. When a user asks ChatGPT, Perplexity, or
        Google's AI Overview for a recommendation, your brand is either cited or it is invisible. There is no page two — there is only the answer.
      </p>
    </div>
  </section>

  <!-- Two-column: TOC + Content -->
  <div class="container-wide py-12 lg:grid lg:grid-cols-[220px_1fr] lg:gap-12">

    <!-- Sticky TOC sidebar -->
    <aside class="hidden lg:block">
      <div class="sticky top-24">
        <span class="eyebrow">On this page</span>
        <nav class="toc mt-4 flex flex-col gap-0.5">
          {tocItems.map(item => (
            <a href={`#${item.id}`}>{item.label}</a>
          ))}
        </nav>
      </div>
    </aside>

    <!-- Main content -->
    <div>

      <!-- Key Takeaways -->
      <div class="card p-6 mb-12">
        <span class="eyebrow">Key Takeaways</span>
        <ul class="mt-4 space-y-2 text-sm text-ink-200">
          <li class="flex items-start gap-2">
            <span class="mt-0.5 text-[var(--accent)]">&#10003;</span>
            <span>GEO is a parallel discipline to SEO, not a bolt-on — it requires specialist tooling, methodology, and monitoring.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-0.5 text-[var(--accent)]">&#10003;</span>
            <span>We track citation frequency, brand accuracy, and cross-platform reach as primary KPIs.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-0.5 text-[var(--accent)]">&#10003;</span>
            <span>Most clients see measurable citation changes within 60-90 days.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-0.5 text-[var(--accent)]">&#10003;</span>
            <span>Our five-stage methodology covers audit, strategy, implementation, monitoring, and iteration.</span>
          </li>
        </ul>
      </div>

      <!-- What a GEO Agency Does -->
      <div class="prose-dark">
        <h2 id="what-geo-agency-does" class="anchor-top">What a GEO Agency Does</h2>
        <p>
          A dedicated <a href="/generative-engine-optimisation/">generative engine optimisation</a>
          agency operates across six core capabilities. Each one addresses a specific mechanism that determines whether AI models cite your brand or a competitor's.
        </p>
      </div>

      <div class="mt-8 grid gap-6 md:grid-cols-2">
        {capabilities.map(cap => (
          <div class="card p-6">
            <h3 class="font-display text-base font-semibold text-[var(--accent)]">{cap.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-ink-300">{cap.text}</p>
          </div>
        ))}
      </div>

      <!-- Why Choose a Specialist GEO Agency -->
      <div class="prose-dark mt-16">
        <h2 id="why-specialist" class="anchor-top">Why Choose a Specialist GEO Agency</h2>
        <p>
          Most digital marketing agencies now mention GEO on their services page. Few have built the infrastructure to deliver it. The difference
          matters because generative engine optimisation is not a variation of SEO — it is a parallel discipline with its own signals, its own
          measurement framework, and its own competitive dynamics.
        </p>
        <p>
          A generalist agency will optimise your title tags and meta descriptions. A specialist GEO agency will audit your entity graph, map your
          citation footprint across five AI platforms, and tell you exactly which content patterns are driving your competitor's mentions in
          Perplexity while yours are absent.
        </p>
        <p>
          We built GEOoptimised around this gap. Our team does not split time between PPC campaigns and GEO audits. Every process, every tool,
          and every analyst is focused on one outcome: making your brand the source that AI models choose to cite.
        </p>
        <p>
          GEOoptimised exists because this shift demands a new discipline. We do not bolt GEO onto an existing SEO retainer. We built the entire
          agency around it — the tooling, the methodology, and the monitoring infrastructure — so that every recommendation we make is grounded in
          how large language models actually select, rank, and cite sources.
        </p>
        <p>
          If you are also exploring <a href="/answer-engine-optimisation/">answer engine optimisation</a>,
          our approach covers that ground too. AEO and GEO share a common foundation — structuring content so that machines can extract and
          present it accurately. The difference is scope: AEO targets featured snippets and voice assistants, while GEO targets the full
          spectrum of generative AI platforms. A specialist <a href="/aeo-agency/">AEO agency</a>
          offering often sits within a broader GEO programme.
        </p>
      </div>

      <!-- Our Approach -->
      <div class="prose-dark mt-16">
        <h2 id="our-approach" class="anchor-top">Our Approach</h2>
        <p>
          Every GEO engagement follows a five-stage methodology designed to produce measurable results within the first 90 days, then compound
          them over time.
        </p>
      </div>

      <ol class="mt-8 space-y-6">
        {steps.map((step, i) => (
          <li class="flex gap-5">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border hair font-display text-sm font-bold text-[var(--accent)]">
              {i + 1}
            </span>
            <div>
              <h3 class="font-display text-lg font-semibold text-white">{step.label}</h3>
              <p class="mt-1 text-sm leading-relaxed text-ink-300">{step.desc}</p>
            </div>
          </li>
        ))}
      </ol>

      <!-- Results We Focus On -->
      <div class="prose-dark mt-16">
        <h2 id="results" class="anchor-top">Results We Focus On</h2>
        <p>
          Vanity metrics do not pay invoices. We measure three outcomes that connect directly to commercial value:
        </p>
      </div>

      <div class="mt-8 grid gap-6 md:grid-cols-3">
        <div class="card p-6 text-center">
          <p class="font-display text-2xl font-bold text-[var(--accent)]">Citation Frequency</p>
          <p class="mt-3 text-sm text-ink-300">
            How often AI engines cite your brand as a source when answering queries in your category. This is the primary KPI for any
            <a href="/geo-services/" class="text-[var(--accent)] border-b border-[var(--accent)]/35 hover:border-[var(--accent)] transition">GEO services</a> engagement.
          </p>
        </div>
        <div class="card p-6 text-center">
          <p class="font-display text-2xl font-bold text-[var(--accent)]">Brand Accuracy</p>
          <p class="mt-3 text-sm text-ink-300">
            Whether AI-generated mentions represent your brand correctly — right name, right positioning, right facts. Inaccurate citations
            can be worse than no citation at all.
          </p>
        </div>
        <div class="card p-6 text-center">
          <p class="font-display text-2xl font-bold text-[var(--accent)]">Cross-Platform Reach</p>
          <p class="mt-3 text-sm text-ink-300">
            Visibility across ChatGPT, Perplexity, Gemini, Copilot, and AI Overviews simultaneously. Dominance on one platform is not
            enough when your customers use several.
          </p>
        </div>
      </div>

      <!-- Good Fit / Not a Fit -->
      <div class="prose-dark mt-16">
        <h2 id="good-fit" class="anchor-top">Good Fit / Not a Fit</h2>
      </div>

      <div class="mt-8 grid gap-6 md:grid-cols-2">
        <div class="card p-6">
          <h3 class="font-display text-base font-semibold text-[var(--accent)]">Good fit</h3>
          <ul class="mt-4 space-y-3 text-sm text-ink-200">
            {goodFit.map(item => (
              <li class="flex items-start gap-2">
                <span class="mt-0.5 text-[var(--accent)]">&#10003;</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="card p-6">
          <h3 class="font-display text-base font-semibold text-ink-300">Not a fit</h3>
          <ul class="mt-4 space-y-3 text-sm text-ink-200">
            {notFit.map(item => (
              <li class="flex items-start gap-2">
                <span class="mt-0.5 text-ink-400">&#10007;</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- FAQ -->
      <div class="prose-dark mt-16">
        <h2 id="faq" class="anchor-top">Frequently Asked Questions</h2>
      </div>

      <div class="mt-8 space-y-2" id="faq-accordion">
        {faqs.map(faq => (
          <div class="card overflow-hidden">
            <button
              type="button"
              class="flex w-full items-center justify-between p-5 text-left text-sm font-semibold text-white transition hover:bg-white/[.02]"
              aria-expanded="false"
            >
              <span>{faq.q}</span>
              <span class="faq-icon ml-4 shrink-0 text-[var(--accent)] transition-transform duration-200">+</span>
            </button>
            <div class="faq-body max-h-0 overflow-hidden transition-[max-height] duration-300 ease-in-out">
              <p class="px-5 pb-5 text-sm leading-relaxed text-ink-300">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Related Reading -->
      <div class="mt-16">
        <span class="eyebrow" id="related">Related reading</span>
        <div class="mt-6 grid gap-6 md:grid-cols-3">
          {related.map(item => (
            <a href={item.href} class="card card-hover block p-5 no-underline">
              <span class="eyebrow">{item.tag}</span>
              <h3 class="mt-2 font-display text-base font-semibold text-white">{item.title}</h3>
              <p class="mt-2 text-sm text-ink-300">{item.excerpt}</p>
              <span class="mt-3 inline-flex items-center gap-1 text-sm text-[var(--accent)]">Read article <span aria-hidden="true">&rarr;</span></span>
            </a>
          ))}
        </div>
      </div>

    </div>
  </div>

  <!-- CTA Banner -->
  <section class="border-t hair mt-12">
    <div class="container-wide py-20 text-center">
      <h2 class="font-display text-3xl font-bold grad-text md:text-4xl">Start With a GEO Audit</h2>
      <p class="mx-auto mt-5 max-w-xl text-ink-300 leading-relaxed">
        Before we propose a strategy, we show you the data. Our GEO audit maps your current AI visibility, identifies the highest-value
        gaps, and gives you a clear picture of what a specialist generative engine optimisation agency can change.
      </p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact/" class="btn btn-primary">Request your free GEO audit</a>
        <a href="/geo-services/" class="btn btn-ghost">View all services</a>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll('#faq-accordion button').forEach(btn => {
      btn.addEventListener('click', () => {
        const body = btn.nextElementSibling;
        const icon = btn.querySelector('.faq-icon');
        const open = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!open));
        if (open) {
          body.style.maxHeight = '0';
          icon.style.transform = 'rotate(0deg)';
        } else {
          body.style.maxHeight = body.scrollHeight + 'px';
          icon.style.transform = 'rotate(45deg)';
        }
      });
    });
  </script>

</Base>
