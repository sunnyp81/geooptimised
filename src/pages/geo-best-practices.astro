            <tr class="transition hover:bg-white/[.02]">
              <td class="px-4 py-3 font-semibold text-white">Section headings</td>
              <td class="px-4 py-3 text-ink-300">Keyword-rich questions (H2s)</td>
              <td class="px-4 py-3 text-ink-300">Declarative labels stating the section's claim</td>
            </tr>
            <tr class="transition hover:bg-white/[.02]">
              <td class="px-4 py-3 font-semibold text-white">Link building</td>
              <td class="px-4 py-3 text-ink-300">PageRank via backlinks</td>
              <td class="px-4 py-3 text-ink-300">Citation footprint in authoritative sources AI models retrieve</td>
            </tr>
            <tr class="transition hover:bg-white/[.02]">
              <td class="px-4 py-3 font-semibold text-white">Primary KPI</td>
              <td class="px-4 py-3 text-ink-300">Organic sessions, keyword rankings</td>
              <td class="px-4 py-3 text-ink-300">Citation frequency, brand accuracy, cross-platform reach</td>
            </tr>
            <tr class="transition hover:bg-white/[.02]">
              <td class="px-4 py-3 font-semibold text-white">Success horizon</td>
              <td class="px-4 py-3 text-ink-300">3–6 months typical for new content</td>
              <td class="px-4 py-3 text-ink-300">60–90 days for citation improvements; 6–12 months for entity authority</td>
