---
import Base from '../layouts/Base.astro';

const title = 'GEO Agency: Generative Engine Optimisation Experts';
const description = 'GEOoptimised is a specialist generative engine optimisation agency. We help brands appear in AI-generated answers across ChatGPT, Perplexity, Gemini and Copilot.';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'ProfessionalService',
    name: 'GEOoptimised',
    url: 'https://geooptimised.com/geo-agency/',
    serviceType: 'Generative Engine Optimisation',
    email: 'hello@geooptimised.com',
    description: 'Specialist generative engine optimisation agency helping brands gain visibility in AI-generated search results.',
    areaServed: {
      '@type': 'Country',
      name: 'United Kingdom',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://geooptimised.com/' },
      { '@type': 'ListItem', position: 2, name: 'GEO Services', item: 'https://geooptimised.com/geo-services/' },
      { '@type': 'ListItem', position: 3, name: 'GEO Agency', item: 'https://geooptimised.com/geo-agency/' },
    ],
  },
];

const capabilities = [
  {
    title: 'AI Citation Auditing',
    text: 'We map exactly where your brand appears — and where it does not — across every major generative engine. This baseline audit reveals the gap between your current AI visibility and what your competitors already hold.',
  },
  {
    title: 'Entity Authority Building',
    text: 'Generative engines rely on entity graphs to decide which brands to cite. We strengthen your entity signals through structured data, authoritative mentions, and consistent knowledge-graph presence so AI models treat your brand as a primary source.',
  },
  {
    title: 'Content Architecture for LLMs',
    text: 'Large language models parse content differently from traditional crawlers. We restructure your pages with clear definitional statements, concise Q&A patterns, and semantic markup that LLMs can extract and cite directly.',
  },
  {
    title: 'Source Credibility Optimisation',
    text: 'AI models weight sources by perceived authority. We build the citation footprint that signals credibility: editorial mentions, industry publications, and high-trust third-party references that feed into training and retrieval-augmented generation pipelines.',
  },
  {
    title: 'Cross-Platform Monitoring',
    text: 'Visibility in one AI engine does not guarantee visibility in another. We track your brand mentions across ChatGPT, Perplexity, Gemini, Copilot, and AI Overviews, then adjust strategy based on platform-specific behaviour.',
  },
  {
    title: 'Competitive Intelligence',
    text: 'We analyse which competitors are being cited for your target queries, reverse-engineer the content and entity patterns driving those citations, and build a strategy to displace them systematically.',
  },
];

const steps = [
  { label: 'Audit', desc: 'Map current AI visibility, citation frequency, and entity coverage across all major generative platforms.' },
  { label: 'Strategy', desc: 'Build a prioritised action plan targeting the queries and platforms with the highest commercial value.' },
  { label: 'Implement', desc: 'Execute content restructuring, entity reinforcement, structured data deployment, and source-building campaigns.' },
  { label: 'Monitor', desc: 'Track citation frequency, brand mention accuracy, and competitive positioning in real time.' },
  { label: 'Iterate', desc: 'Refine strategy based on measured results. Generative engines evolve rapidly — your GEO programme must evolve faster.' },
];
---

<Base title={title} description={description} schema={schema} ogType="website">

  <!-- Breadcrumb -->
  <nav aria-label="Breadcrumb" class="mx-auto max-w-4xl px-4 pt-8 text-sm text-gray-400">
    <ol class="flex items-center gap-1.5">
      <li><a href="/" class="hover:text-accent-400 transition">Home</a></li>
      <li aria-hidden="true">/</li>
      <li><a href="/geo-services/" class="hover:text-accent-400 transition">GEO Services</a></li>
      <li aria-hidden="true">/</li>
      <li class="text-gray-200" aria-current="page">GEO Agency</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="mx-auto max-w-4xl px-4 pt-16 pb-12">
    <h1 class="text-4xl font-extrabold leading-tight tracking-tight text-white md:text-5xl">
      GEO Agency: Generative Engine Optimisation Experts
    </h1>
    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-gray-300">
      Traditional SEO targets search engine results pages. A <strong class="text-white">generative engine optimisation agency</strong> targets
      something fundamentally different: the AI-generated answers that are replacing those results. When a user asks ChatGPT, Perplexity, or
      Google's AI Overview for a recommendation, your brand is either cited or it is invisible. There is no page two — there is only the answer.
    </p>
    <p class="mt-4 max-w-2xl text-lg leading-relaxed text-gray-300">
      GEOoptimised exists because this shift demands a new discipline. We do not bolt GEO onto an existing SEO retainer. We built the entire
      agency around it — the tooling, the methodology, and the monitoring infrastructure — so that every recommendation we make is grounded in
      how large language models actually select, rank, and cite sources.
    </p>
  </section>

  <!-- What a GEO Agency Does -->
  <section class="mx-auto max-w-4xl px-4 py-12">
    <h2 class="text-3xl font-bold text-white">What a GEO Agency Does</h2>
    <p class="mt-4 max-w-2xl text-gray-300 leading-relaxed">
      A dedicated <a href="/generative-engine-optimisation/" class="text-accent-400 underline decoration-accent-500/40 hover:decoration-accent-400 transition">generative engine optimisation</a>
      agency operates across six core capabilities. Each one addresses a specific mechanism that determines whether AI models cite your brand or a competitor's.
    </p>
    <div class="mt-10 grid gap-8 md:grid-cols-2">
      {capabilities.map(cap => (
        <div class="rounded-xl border border-geo-700/50 bg-geo-900/60 p-6">
          <h3 class="text-lg font-semibold text-accent-400">{cap.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-gray-300">{cap.text}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Why Choose a Specialist GEO Agency -->
  <section class="mx-auto max-w-4xl px-4 py-12">
    <h2 class="text-3xl font-bold text-white">Why Choose a Specialist GEO Agency</h2>
    <p class="mt-4 max-w-2xl text-gray-300 leading-relaxed">
      Most digital marketing agencies now mention GEO on their services page. Few have built the infrastructure to deliver it. The difference
      matters because generative engine optimisation is not a variation of SEO — it is a parallel discipline with its own signals, its own
      measurement framework, and its own competitive dynamics.
    </p>
    <p class="mt-4 max-w-2xl text-gray-300 leading-relaxed">
      A generalist agency will optimise your title tags and meta descriptions. A specialist GEO agency will audit your entity graph, map your
      citation footprint across five AI platforms, and tell you exactly which content patterns are driving your competitor's mentions in
      Perplexity while yours are absent.
    </p>
    <p class="mt-4 max-w-2xl text-gray-300 leading-relaxed">
      We built GEOoptimised around this gap. Our team does not split time between PPC campaigns and GEO audits. Every process, every tool,
      and every analyst is focused on one outcome: making your brand the source that AI models choose to cite.
    </p>
    <p class="mt-4 max-w-2xl text-gray-300 leading-relaxed">
      If you are also exploring <a href="/answer-engine-optimisation/" class="text-accent-400 underline decoration-accent-500/40 hover:decoration-accent-400 transition">answer engine optimisation</a>,
      our approach covers that ground too. AEO and GEO share a common foundation — structuring content so that machines can extract and
      present it accurately. The difference is scope: AEO targets featured snippets and voice assistants, while GEO targets the full
      spectrum of generative AI platforms. A specialist <a href="/aeo-agency/" class="text-accent-400 underline decoration-accent-500/40 hover:decoration-accent-400 transition">AEO agency</a>
      offering often sits within a broader GEO programme.
    </p>
  </section>

  <!-- Our Approach -->
  <section class="mx-auto max-w-4xl px-4 py-12">
    <h2 class="text-3xl font-bold text-white">Our Approach</h2>
    <p class="mt-4 max-w-2xl text-gray-300 leading-relaxed">
      Every GEO engagement follows a five-stage methodology designed to produce measurable results within the first 90 days, then compound
      them over time.
    </p>
    <ol class="mt-10 space-y-6">
      {steps.map((step, i) => (
        <li class="flex gap-5">
          <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-accent-500/40 bg-geo-900 text-sm font-bold text-accent-400">
            {i + 1}
          </span>
          <div>
            <h3 class="text-lg font-semibold text-white">{step.label}</h3>
            <p class="mt-1 text-sm leading-relaxed text-gray-300">{step.desc}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <!-- Results We Focus On -->
  <section class="mx-auto max-w-4xl px-4 py-12">
    <h2 class="text-3xl font-bold text-white">Results We Focus On</h2>
    <p class="mt-4 max-w-2xl text-gray-300 leading-relaxed">
      Vanity metrics do not pay invoices. We measure three outcomes that connect directly to commercial value:
    </p>
    <div class="mt-8 grid gap-6 md:grid-cols-3">
      <div class="rounded-xl border border-geo-700/50 bg-geo-900/60 p-6 text-center">
        <p class="text-3xl font-extrabold text-accent-400">Citation Frequency</p>
        <p class="mt-3 text-sm text-gray-300">
          How often AI engines cite your brand as a source when answering queries in your category. This is the primary KPI for any
          <a href="/geo-services/" class="text-accent-400 underline decoration-accent-500/40 hover:decoration-accent-400 transition">GEO services</a> engagement.
        </p>
      </div>
      <div class="rounded-xl border border-geo-700/50 bg-geo-900/60 p-6 text-center">
        <p class="text-3xl font-extrabold text-accent-400">Brand Accuracy</p>
        <p class="mt-3 text-sm text-gray-300">
          Whether AI-generated mentions represent your brand correctly — right name, right positioning, right facts. Inaccurate citations
          can be worse than no citation at all.
        </p>
      </div>
      <div class="rounded-xl border border-geo-700/50 bg-geo-900/60 p-6 text-center">
        <p class="text-3xl font-extrabold text-accent-400">Cross-Platform Reach</p>
        <p class="mt-3 text-sm text-gray-300">
          Visibility across ChatGPT, Perplexity, Gemini, Copilot, and AI Overviews simultaneously. Dominance on one platform is not
          enough when your customers use several.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-4xl px-4 pt-12 pb-20 text-center">
    <h2 class="text-3xl font-bold text-white">Start With a GEO Audit</h2>
    <p class="mx-auto mt-4 max-w-xl text-gray-300 leading-relaxed">
      Before we propose a strategy, we show you the data. Our GEO audit maps your current AI visibility, identifies the highest-value
      gaps, and gives you a clear picture of what a specialist generative engine optimisation agency can change.
    </p>
    <a
      href="/contact/"
      class="mt-8 inline-block rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-geo-950 shadow-lg shadow-accent-500/20 transition hover:bg-accent-400 hover:shadow-accent-400/30"
    >
      Request your free GEO audit
    </a>
  </section>

</Base>
