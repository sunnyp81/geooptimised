---
const nav = [
  { href: '/evidence/', label: 'Evidence ledger' },
  { href: '/reproduction/', label: 'The study' },
  { href: '/how-to-be-found-in-ai-search/', label: 'AI search' },
  { href: '/tools/', label: 'Tools' },
  { href: '/who-pays-us/', label: 'Who pays us' },
  { href: '/methodology/', label: 'Method' },
  { href: '/about/', label: 'About' },
];
const path = Astro.url.pathname;
---
<header class="sticky top-0 z-40 nav-glass">
  <div class="wrap flex items-center justify-between h-16 gap-4">
    <a href="/" class="flex items-baseline gap-2.5 shrink-0" aria-label="GEOoptimised home">
      <span class="font-display text-xl font-bold" style="color: var(--text);">GEOoptimised</span>
      <span class="eyebrow hidden sm:inline">Evidence, graded</span>
    </a>

    <nav class="hidden md:flex items-center gap-6" aria-label="Primary">
      {nav.map(item => (
        <a
          href={item.href}
          class="text-[0.9rem]"
          style={`color: ${path.startsWith(item.href) ? 'var(--text)' : 'var(--muted)'}; ${path.startsWith(item.href) ? 'font-weight:600;' : ''}`}
          aria-current={path.startsWith(item.href) ? 'page' : undefined}
        >{item.label}</a>
      ))}
    </nav>

    <button
      id="nav-toggle"
      class="md:hidden data text-[0.7rem] uppercase tracking-widest border px-3 py-1.5"
      style="color: var(--text); border-color: var(--line-strong);"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >Menu</button>
  </div>

  <nav id="mobile-nav" class="md:hidden hidden border-t" style="border-color: var(--line);" aria-label="Primary mobile">
    <div class="wrap py-3 flex flex-col">
      {nav.map(item => (
        <a href={item.href} class="py-2.5 text-[0.95rem] border-b last:border-b-0" style="color: var(--text); border-color: var(--line);">{item.label}</a>
      ))}
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-nav');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(open));
    btn.textContent = open ? 'Close' : 'Menu';
  });
</script>
