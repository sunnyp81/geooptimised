                <tr>
                  <td class="px-5 py-3 font-medium text-ink-100">Featured Snippet Win Rate</td>
                  <td class="px-5 py-3">% of target queries where you hold position zero</td>
                  <td class="px-5 py-3">Semrush, Ahrefs, GSC</td>
                  <td class="px-5 py-3">60 days</td>
                </tr>
                <tr>
                  <td class="px-5 py-3 font-medium text-ink-100">People Also Ask Appearances</td>
                  <td class="px-5 py-3">Count of PAA boxes where your content is selected</td>
                  <td class="px-5 py-3">Semrush, AlsoAsked</td>
                  <td class="px-5 py-3">60 days</td>
                </tr>
                <tr>
                  <td class="px-5 py-3 font-medium text-ink-100">AI Overview Citation Frequency</td>
                  <td class="px-5 py-3">% of monitored queries where AI Overviews cite your domain</td>
                  <td class="px-5 py-3">Profound, Semrush AI Toolkit</td>
                  <td class="px-5 py-3">90 days</td>
                </tr>
                <tr>
                  <td class="px-5 py-3 font-medium text-ink-100">Voice Answer Selection</td>
                  <td class="px-5 py-3">% of tested voice queries where your content is read aloud</td>
                  <td class="px-5 py-3">Manual testing protocol</td>
                  <td class="px-5 py-3">90 days</td>
                </tr>
                <tr>
                  <td class="px-5 py-3 font-medium text-ink-100">Zero-Click Impression Share</td>
                  <td class="px-5 py-3">Impressions for queries with no click required, as % of total</td>
