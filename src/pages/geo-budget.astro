const title = 'GEO Budget: How to Plan Your Investment | GEOoptimised';
const description = 'How to plan a GEO budget: cost drivers, allocation across audit, content, and monitoring, and illustrative investment ranges for programmes of different scales.';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: 'GEO Budget: How to Plan Your Investment',
    description: 'How to plan a GEO budget: cost drivers, allocation across audit, content, and monitoring, and illustrative investment ranges for programmes of different scales.',
    url: 'https://geooptimised.com/geo-budget/',
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': 'https://geooptimised.com/geo-budget/'
    },
    image: 'https://geooptimised.com/og-image.png',
    datePublished: '2026-06-07',
    dateModified: '2026-06-07',
    inLanguage: 'en-GB',
    author: {
      '@id': 'https://geooptimised.com/#organization'
    },
    publisher: {
      '@id': 'https://geooptimised.com/#organization'
    }
  },
