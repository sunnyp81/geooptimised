      <li class="text-ink-200" aria-current="page">How AEO Works</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="hero-fade">
    <div class="container-wide pt-16 pb-14">
      <div class="flex flex-wrap items-center gap-3">
        <span class="eyebrow">Deep Dive</span>
        <span class="font-mono text-xs text-ink-300">7 June 2026</span>
