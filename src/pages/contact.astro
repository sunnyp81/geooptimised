---
import Base from '../layouts/Base.astro';

const title = 'Contact GEOoptimised — Free AI Visibility Audit';
const description = 'Request a free AI visibility audit from GEOoptimised. We assess your brand citation performance across ChatGPT, Perplexity, Gemini and Google AI Overviews, then show you exactly what to fix.';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "Contact GEOoptimised — Free AI Visibility Audit",
    "url": "https://geooptimised.com/contact/",
    "description": "Contact GEOoptimised to start your Generative Engine Optimisation journey with a free AI visibility assessment across ChatGPT, Perplexity, Gemini and Google AI Overviews.",
    "mainEntity": {
      "@type": "Organization",
      "name": "GEOoptimised",
      "url": "https://geooptimised.com",
      "email": "hello@geooptimised.com"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Free AI Visibility Audit",
    "provider": {
      "@type": "Organization",
      "name": "GEOoptimised",
      "url": "https://geooptimised.com"
    },
    "serviceType": "Generative Engine Optimisation Audit",
    "description": "A no-obligation audit assessing how your brand is cited across ChatGPT, Perplexity, Gemini, Google AI Overviews and Microsoft Copilot, with a competitor benchmark and prioritised action plan.",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "GBP",
      "description": "Free initial AI visibility audit with no obligation"
    },
    "areaServed": "Worldwide"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://geooptimised.com/" },
      { "@type": "ListItem", "position": 2, "name": "Contact", "item": "https://geooptimised.com/contact/" }
    ]
  }
];

const whatYouGet = [
  'AI citation audit across ChatGPT, Perplexity, Gemini and Copilot',
  'Entity graph analysis for your brand',
  'Competitor citation benchmarking',
  'Content gap identification for AI visibility',
  'Prioritised action plan with estimated impact',
  'No-obligation strategy call to walk through findings',
];

const timeline = [
  { day: 'Day 0', action: 'Submit your details below' },
  { day: 'Day 1', action: 'We run your AI visibility audit' },
  { day: 'Day 2-3', action: 'Entity and competitor analysis' },
  { day: 'Day 4', action: 'Report compiled with recommendations' },
  { day: 'Day 5', action: 'Strategy call to review findings' },
];
---

<Base title={title} description={description} schema={schema}>

  <!-- Breadcrumb -->
  <nav aria-label="Breadcrumb" class="container-wide pt-8">
    <ol class="flex items-center gap-1.5 text-sm text-ink-400">
      <li><a href="/" class="transition hover:text-[var(--accent)]">Home</a></li>
      <li aria-hidden="true">/</li>
      <li class="text-ink-200" aria-current="page">Contact</li>
    </ol>
  </nav>

  <!-- Header -->
  <section class="hero-fade">
    <div class="container-wide pt-16 pb-14 text-center">
      <span class="eyebrow">Free AI Visibility Audit</span>
      <h1 class="mx-auto mt-5 max-w-3xl font-display text-4xl font-bold leading-tight grad-text md:text-5xl lg:text-6xl">
        Find out how often AI cites you. Or doesn't.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-ink-200">
        We start every engagement with a <strong class="text-white">free AI visibility assessment</strong>. We audit how your brand currently performs across ChatGPT, Perplexity, Gemini and Google AI Overviews — and show you exactly where the opportunities are. No commitment, no obligation. Just data.
      </p>
      <p class="mt-3 text-ink-400">
        You can also reach us directly at <a href="mailto:hello@geooptimised.com" class="text-[var(--accent)] border-b border-[var(--accent)]/35 hover:border-[var(--accent)] transition">hello@geooptimised.com</a>.
      </p>
    </div>
  </section>

  <!-- Success message (shown after formsubmit redirect) -->
  <div id="success-banner" class="hidden container-wide mb-8">
    <div class="card p-6 border-[var(--accent)]/40 bg-[var(--accent)]/5 flex items-start gap-4" role="alert">
      <svg aria-hidden="true" class="w-6 h-6 text-[var(--accent)] mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <div>
        <p class="font-semibold text-white">Message sent — thank you.</p>
        <p class="mt-1 text-sm text-ink-300">We will review your details and be in touch within one business day to confirm your audit is underway.</p>
      </div>
    </div>
  </div>

  <!-- Form + Sidebar -->
  <section class="container-wide pb-20">
    <div class="grid gap-10 lg:grid-cols-[7fr_5fr]">

      <!-- Left: Form -->
      <div class="card p-8">
        <form action="https://formsubmit.co/hello@geooptimised.com" method="POST" class="space-y-6">

          <div class="grid gap-6 sm:grid-cols-2">
            <div>
              <label for="name" class="block text-sm font-medium text-ink-200">Name</label>
              <input type="text" id="name" name="name" required autocomplete="name"
                class="input mt-2" placeholder="Your name" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-ink-200">Email</label>
              <input type="email" id="email" name="email" required autocomplete="email"
                class="input mt-2" placeholder="you@company.com" />
            </div>
          </div>

          <div>
            <label for="website" class="block text-sm font-medium text-ink-200">Website URL</label>
            <input type="url" id="website" name="website" autocomplete="url"
              class="input mt-2" placeholder="https://yoursite.com" />
          </div>

          <!-- Focus selector: 3 toggle buttons -->
          <fieldset>
            <legend class="block text-sm font-medium text-ink-200 mb-2">Primary focus</legend>
            <div class="flex flex-wrap gap-2" id="focus-group">
              <button type="button" data-value="GEO" aria-pressed="false" class="focus-btn btn btn-ghost text-sm px-4 py-2">GEO</button>
              <button type="button" data-value="AEO" aria-pressed="false" class="focus-btn btn btn-ghost text-sm px-4 py-2">AEO</button>
              <button type="button" data-value="Both" aria-pressed="false" class="focus-btn btn btn-ghost text-sm px-4 py-2">Both / Not sure</button>
            </div>
            <input type="hidden" name="focus" id="focus-input" value="" />
          </fieldset>

          <!-- Budget range: pill buttons -->
          <fieldset>
            <legend class="block text-sm font-medium text-ink-200 mb-2">Monthly budget range</legend>
            <div class="flex flex-wrap gap-2" id="budget-group">
              <button type="button" data-value="Under £1k" aria-pressed="false" class="budget-btn btn btn-ghost text-sm px-4 py-2">Under &pound;1k</button>
              <button type="button" data-value="£1k-3k" aria-pressed="false" class="budget-btn btn btn-ghost text-sm px-4 py-2">&pound;1k-3k</button>
              <button type="button" data-value="£3k-5k" aria-pressed="false" class="budget-btn btn btn-ghost text-sm px-4 py-2">&pound;3k-5k</button>
              <button type="button" data-value="£5k+" aria-pressed="false" class="budget-btn btn btn-ghost text-sm px-4 py-2">&pound;5k+</button>
            </div>
            <input type="hidden" name="budget" id="budget-input" value="" />
          </fieldset>

          <div>
            <label for="message" class="block text-sm font-medium text-ink-200">Tell us about your goals</label>
            <textarea id="message" name="message" rows="4" required
              class="input mt-2 resize-y"
              placeholder="What would you like help with?"></textarea>
          </div>

          <!-- FormSubmit config -->
          <input type="hidden" name="_subject" value="New GEO enquiry from geooptimised.com" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_next" value="https://geooptimised.com/contact/?submitted=true" />
          <input type="text" name="_honey" style="display:none" />

          <button type="submit" class="btn btn-primary w-full justify-center">
            Send Message
          </button>

        </form>
      </div>

      <!-- Right: Sidebar cards -->
      <div class="space-y-6">

        <!-- What you get -->
        <div class="card p-6">
          <span class="eyebrow">What you get</span>
          <ul class="mt-4 space-y-3 text-sm text-ink-200">
            {whatYouGet.map(item => (
              <li class="flex items-start gap-2">
                <span class="mt-0.5 text-[var(--accent)]">&#10003;</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Timeline -->
        <div class="card p-6">
          <span class="eyebrow">Timeline</span>
          <ol class="mt-4 space-y-3 text-sm">
            {timeline.map(item => (
              <li class="flex gap-3">
                <span class="font-mono text-xs text-[var(--accent)] whitespace-nowrap mt-0.5">{item.day}</span>
                <span class="text-ink-200">{item.action}</span>
              </li>
            ))}
          </ol>
        </div>

        <!-- What clients say -->
        <div class="card p-6">
          <span class="eyebrow">What to expect</span>
          <p class="mt-4 text-sm text-ink-200 leading-relaxed">
            <strong class="text-white">Most brands are surprised by what the audit reveals.</strong> Many are invisible across AI platforms despite strong Google rankings. The audit typically uncovers both quick-win content fixes and longer-term structural opportunities.
          </p>
          <p class="mt-3 text-sm text-ink-300 leading-relaxed">
            The strategy call on Day 5 walks through the findings in plain language — no jargon, just a prioritised list of what to fix and why.
          </p>
          <div class="mt-4 pt-4 border-t border-[var(--line)]">
            <p class="text-xs text-ink-400">Questions first? Email us at <a href="mailto:hello@geooptimised.com" class="text-accent-400 underline decoration-accent-500/30 underline-offset-2 hover:text-accent-300">hello@geooptimised.com</a></p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Internal links -->
  <section class="container-wide pb-16">
    <div class="border-t border-[var(--line)] pt-10 text-center text-sm text-ink-400">
      <p>Not ready to submit? Learn more about <a href="/generative-engine-optimisation/" class="text-accent-400 underline decoration-accent-500/30 underline-offset-2 hover:text-accent-300">what GEO is</a>, explore our <a href="/geo-services/" class="text-accent-400 underline decoration-accent-500/30 underline-offset-2 hover:text-accent-300">GEO services</a>, or <a href="/" class="text-accent-400 underline decoration-accent-500/30 underline-offset-2 hover:text-accent-300">return to the homepage</a>.</p>
    </div>
  </section>

  <script>
    function initToggleGroup(groupId, inputId) {
      const btns = document.querySelectorAll(`#${groupId} button`);
      const input = document.getElementById(inputId);
      btns.forEach(btn => {
        btn.addEventListener('click', () => {
          btns.forEach(b => {
            b.style.background = '';
            b.style.borderColor = '';
            b.style.color = '';
            b.setAttribute('aria-pressed', 'false');
          });
          btn.style.background = 'var(--accent)';
          btn.style.borderColor = 'var(--accent)';
          btn.style.color = '#00231F';
          btn.setAttribute('aria-pressed', 'true');
          input.value = btn.dataset.value;
        });
      });
    }
    initToggleGroup('focus-group', 'focus-input');
    initToggleGroup('budget-group', 'budget-input');

    // Show success confirmation when redirected back with ?submitted=true
    if (new URLSearchParams(window.location.search).get('submitted') === 'true') {
      const banner = document.getElementById('success-banner');
      if (banner) {
        banner.classList.remove('hidden');
        banner.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    }
  </script>

</Base>
