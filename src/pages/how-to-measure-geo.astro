              <th scope="col" class="px-4 py-3 text-left font-semibold text-white">Action</th>
              <th scope="col" class="px-4 py-3 text-left font-semibold text-white">Output</th>
            </tr>
          </thead>
          <tbody class="divide-y hair">
            <tr class="transition hover:bg-white/[.02]">
              <td class="px-4 py-3 font-mono text-xs text-[var(--accent)]">1</td>
              <td class="px-4 py-3 font-semibold text-white">Define your query set</td>
              <td class="px-4 py-3 text-ink-300">20–50 queries across brand, category, and problem-framing intent; stable and reused each month</td>
            </tr>
            <tr class="transition hover:bg-white/[.02]">
              <td class="px-4 py-3 font-mono text-xs text-[var(--accent)]">2</td>
              <td class="px-4 py-3 font-semibold text-white">Run citation sampling</td>
              <td class="px-4 py-3 text-ink-300">Citation frequency per platform and query category; raw response log for sentiment review</td>
            </tr>
            <tr class="transition hover:bg-white/[.02]">
              <td class="px-4 py-3 font-mono text-xs text-[var(--accent)]">3</td>
              <td class="px-4 py-3 font-semibold text-white">Calculate share of voice</td>
              <td class="px-4 py-3 text-ink-300">Your brand's citation share versus key competitors on the same query set</td>
            </tr>
