            <button
              type="button"
              class="flex w-full items-center justify-between py-5 text-left font-display text-lg font-semibold text-ink-100 hover:text-[var(--accent)] transition-colors"
              aria-expanded="false"
            >
              <span>{faq.q}</span>
              <svg class="faq-icon ml-4 h-5 w-5 shrink-0 text-ink-500 transition-transform duration-200" viewBox="0 0 20 20" fill="currentColor">
                <path d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z"/>
              </svg>
            </button>
            <div class="faq-answer overflow-hidden transition-all duration-300" style="max-height:0">
              <p class="pb-5 text-ink-300 leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>

  <section class="border-t hair mt-12">
    <div class="container-wide py-20">
      <div class="relative overflow-hidden rounded-2xl dot-grid">
        <div class="absolute inset-0 bg-gradient-to-br from-[rgba(var(--accent-glow),.12)] via-transparent to-transparent"></div>
        <div class="relative px-8 py-16 text-center sm:px-16">
          <span class="eyebrow">Get Started</span>
          <h2 class="mt-4 font-display text-3xl font-bold text-ink-50 sm:text-4xl">See Where Your Brand Stands in AI Search</h2>
          <p class="mt-4 mx-auto max-w-2xl text-ink-300 leading-relaxed">
            A GEO audit maps your current citation frequency across ChatGPT, Perplexity, Gemini, Copilot, and AI Overviews, identifies which competitors are being cited in your place, and produces a prioritised action plan. It is the right starting point whether you are adding GEO to an existing SEO programme or building from scratch.
          </p>
          <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
            <a href="/contact/" class="btn btn-primary">Request a free GEO audit</a>
            <a href="/geo-services/" class="btn btn-ghost">View GEO services</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-20">
    <span class="eyebrow" id="related">Related reading</span>
    <div class="mt-6 grid gap-6 md:grid-cols-3">
      {related.map(item => (
        <a href={item.href} class="card card-hover block p-5 no-underline">
          <span class="eyebrow">{item.tag}</span>
          <h3 class="mt-2 font-display text-base font-semibold text-white">{item.title}</h3>
          <p class="mt-2 text-sm text-ink-300">{item.excerpt}</p>
          <span class="mt-3 inline-flex items-center gap-1 text-sm text-[var(--accent)]">Read article <span aria-hidden="true">&rarr;</span></span>
        </a>
      ))}
    </div>
  </section>

  <script>
    const tocLinks = document.querySelectorAll('.toc a');
    const sections = document.querySelectorAll('.anchor-top');
    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          tocLinks.forEach(l => l.classList.remove('active'));
          const id = entry.target.id;
          const active = document.querySelector(`.toc a[href="#${id}"]`);
          if (active) active.classList.add('active');
        }
      });
    }, { rootMargin: '-20% 0px -80% 0px' });
    sections.forEach(s => observer.observe(s));

    document.querySelectorAll('.faq-item button').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        const answer = item.querySelector('.faq-answer');
        const icon = item.querySelector('.faq-icon');
        const isOpen = btn.getAttribute('aria-expanded') === 'true';
        document.querySelectorAll('.faq-item button[aria-expanded="true"]').forEach(other => {
          if (other !== btn) {
            other.setAttribute('aria-expanded', 'false');
            other.closest('.faq-item').querySelector('.faq-answer').style.maxHeight = '0';
            other.closest('.faq-item').querySelector('.faq-icon').style.transform = '';
          }
        });
        btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
        answer.style.maxHeight = isOpen ? '0' : answer.scrollHeight + 'px';
        icon.style.transform = isOpen ? '' : 'rotate(45deg)';
      });
    });
  </script>

</Base>
