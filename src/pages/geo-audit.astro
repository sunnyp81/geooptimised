  { id: 'step-by-step-framework', label: 'Step-by-Step Framework' },
  { id: 'diy-audit-table', label: 'DIY Audit Table' },
  { id: 'faq', label: 'FAQ' },
  { id: 'related', label: 'Related Reading' }
];

const auditDimensions = [
  {
    dimension: 'Entity clarity',
    what: 'Consistency and unambiguity of brand identity across the web',
    signals: 'Business name, category, description, founding date, sameAs links',
    sources: 'Website, GBP, Wikidata, LinkedIn, schema',
