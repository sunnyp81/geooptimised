              >
                <span>{faq.q}</span>
                <svg class="faq-icon ml-4 h-5 w-5 shrink-0 text-ink-500 transition-transform duration-200" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z"/>
                </svg>
              </button>
              <div class="faq-answer overflow-hidden transition-all duration-300" style="max-height:0">
                <p class="pb-5 text-ink-300 leading-relaxed">{faq.a}</p>
