];

const tocItems = [
  { id: 'why-budget-differently', label: 'Why GEO Needs Its Own Budget' },
  { id: 'cost-drivers', label: 'The Four Cost Drivers' },
  { id: 'allocation', label: 'Budget Allocation' },
  { id: 'illustrative-ranges', label: 'Illustrative Ranges' },
  { id: 'sequencing', label: 'How to Sequence Spend' },
  { id: 'roi-frame', label: 'Framing ROI for Stakeholders' },
  { id: 'faq', label: 'FAQ' },
  { id: 'related', label: 'Related Reading' },
];

const costDrivers = [
  {
    driver: 'Audit & baseline',
    description: 'Initial citation frequency analysis, entity consistency review, technical access audit, and competitive share-of-voice snapshot. The foundation that calibrates all subsequent spend.',
    scaleFactors: 'Number of target queries, number of competitors benchmarked, breadth of platforms assessed.',
  },
  {
    driver: 'Content production',
    description: 'Creating new pages for topical authority and updating existing pages for extraction quality. The largest cost driver in most programmes, scaling with the content gap identified in the audit.',
    scaleFactors: 'Number of pages required, content complexity (technical vs general), need for original research or data.',
  },
  {
    driver: 'Entity management',
    description: 'Establishing and maintaining consistent entity signals across your website, structured data, third-party directories, and external sources. Ongoing rather than one-off in competitive markets.',
    scaleFactors: 'Current level of entity inconsistency, number of platforms requiring correction, presence or absence of existing Wikidata / knowledge graph entries.',
  },
  {
    driver: 'Monitoring & reporting',
    description: 'Monthly query sampling, AI referral traffic analysis, sentiment review, and scorecard production. Tooling costs and analyst time scale with programme breadth and reporting frequency requirements.',
    scaleFactors: 'Number of queries monitored, number of platforms, frequency of reporting, whether automated tooling or manual sampling is used.',
  },
];

const allocationRows = [
  {
    phase: 'Months 1–2',
    focus: 'Audit & baseline',
    allocation: 'Majority of initial budget',
    rationale: 'Establishes evidence base for all subsequent spend; prevents misallocation on low-impact activities',
  },
  {
    phase: 'Months 2–4',
    focus: 'Priority content & entity corrections',
    allocation: 'Largest ongoing component',
    rationale: 'Addresses the highest-impact gaps identified in audit; targets queries closest to citation threshold',
  },
  {
    phase: 'Ongoing',
    focus: 'Monitoring, reporting & optimisation',
    allocation: 'Steady-state recurring cost',
    rationale: 'Maintains measurement cadence, catches citation drift, and identifies new opportunities as AI platforms evolve',
  },
  {
    phase: 'Ongoing',
