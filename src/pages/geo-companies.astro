      { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://geooptimised.com/geo-services/" },
      { "@type": "ListItem", "position": 3, "name": "GEO Companies", "item": "https://geooptimised.com/geo-companies/" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What makes a good GEO company?", "acceptedAnswer": { "@type": "Answer", "text": "A good GEO company has dedicated AI visibility tooling, can demonstrate citation tracking across multiple platforms, employs specialists with entity optimisation expertise, and measures results in terms of citation frequency rather than just organic rankings." } },
      { "@type": "Question", "name": "How many GEO companies exist?", "acceptedAnswer": { "@type": "Answer", "text": "GEO is a nascent discipline. A growing number of digital agencies claim GEO capability, but the number with dedicated methodology, proprietary tooling, and verifiable citation results remains small. The best way to assess any provider is to ask for citation data, not just ranking reports." } },
      { "@type": "Question", "name": "How much do GEO companies charge?", "acceptedAnswer": { "@type": "Answer", "text": "GEO pricing varies significantly by scope and provider type. A standalone audit from a specialist is typically a four-figure investment; ongoing retainers range from a few thousand pounds per month for focused programmes to significantly more for enterprise, multi-platform engagements. The right investment depends on your competitive landscape, the number of platforms covered, and the commercial opportunity at stake." } },
      { "@type": "Question", "name": "Should I choose a GEO specialist or a full-service agency?", "acceptedAnswer": { "@type": "Answer", "text": "If your organic SEO foundation is solid and your priority is AI visibility, a specialist GEO company is typically the better investment — their entire methodology and tooling is built around citation outcomes. If you need both SEO and GEO from scratch, a full-service agency with genuine GEO capability is the pragmatic choice." } },
      { "@type": "Question", "name": "What questions should I ask a GEO company before hiring?", "acceptedAnswer": { "@type": "Answer", "text": "Ask: What citation tracking tools do you use? Can you show me before-and-after citation data? How do you measure GEO success? Which AI platforms do you optimise for? What is your entity optimisation methodology? How frequently do you update strategy based on platform changes?" } }
    ]
  }
